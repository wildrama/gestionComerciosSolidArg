<%- include('../partials/headerAdm.ejs'); %>
<%
    const currentFilters = (typeof filters !== 'undefined' && filters) ? filters : { desde: '', hasta: '', q: '' };
    const currentSummary = (typeof summary !== 'undefined' && summary) ? summary : {
        totalCount: (cierresDeCaja || []).length,
        totalVentas: (cierresDeCaja || []).reduce((acc, cierre) => acc + Number((cierre.ventasEnEfectivo?.montoTotal || 0) + (cierre.ventasEnOtro?.montoTotal || 0)), 0),
        totalEnCaja: (cierresDeCaja || []).reduce((acc, cierre) => acc + Number(cierre.dineroReal || cierre.dineroEnCaja || 0), 0),
        totalRetiros: (cierresDeCaja || []).reduce((acc, cierre) => acc + Number(cierre.egresosManualDinero?.montoTotal || 0), 0),
        lastClose: (cierresDeCaja && cierresDeCaja[0]) ? cierresDeCaja[0].fechaDeCierre : null
    };
%>

<div class="admin-dashboard">
    <div class="form-container">
        <nav class="breadcrumb-nav">
            <a href="/administrador" class="breadcrumb-link">Dashboard</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current">Cierres de Caja</span>
        </nav>

        <div class="form-header">
            <h1 class="form-title">🧾 Historial de cierres</h1>
            <p class="form-subtitle">Consultá los cierres realizados y filtrá por fecha, usuario, estación o período.</p>
        </div>

        <form method="GET" action="/administrador/cierres-caja" class="cierres-filter-bar">
            <div class="filter-field">
                <label for="desde" class="filter-label">Desde</label>
                <input type="date" id="desde" name="desde" class="form-control-modern" value="<%= currentFilters.desde || '' %>">
            </div>
            <div class="filter-field">
                <label for="hasta" class="filter-label">Hasta</label>
                <input type="date" id="hasta" name="hasta" class="form-control-modern" value="<%= currentFilters.hasta || '' %>">
            </div>
            <div class="filter-field search-field">
                <label for="q" class="filter-label">Buscar</label>
                <input type="text" id="q" name="q" class="form-control-modern" placeholder="Caja, usuario, período..." value="<%= currentFilters.q || '' %>">
            </div>
            <div class="filter-actions">
                <button type="submit" class="btn-primary-modern cierres-filter-submit">🔎 Filtrar</button>
                <a href="/administrador/cierres-caja" class="btn-secondary-modern cierres-filter-reset">Limpiar</a>
            </div>
        </form>

        <div class="cierres-summary-grid">
            <article class="cierres-summary-card neutral">
                <span>Total de cierres</span>
                <strong><%= currentSummary.totalCount || 0 %></strong>
            </article>
            <article class="cierres-summary-card sales-highlight">
                <span>Total ventas del período</span>
                <strong>$<%= Number(currentSummary.totalVentas || 0).toFixed(2) %></strong>
            </article>
            <article class="cierres-summary-card withdrawals-highlight">
                <span>Retiros de caja</span>
                <strong>$<%= Number(currentSummary.totalRetiros || 0).toFixed(2) %></strong>
            </article>
            <article class="cierres-summary-card cash-highlight">
                <span>Dinero contado</span>
                <strong>$<%= Number(currentSummary.totalEnCaja || 0).toFixed(2) %></strong>
            </article>
            <article class="cierres-summary-card neutral">
                <span>Último cierre</span>
                <strong><%= currentSummary.lastClose ? new Date(currentSummary.lastClose).toLocaleDateString('es-AR') : '—' %></strong>
            </article>
        </div>

        <% if (cierresDeCaja && cierresDeCaja.length > 0) { %>
            <div class="cierres-table-shell">
                <table class="cierres-table">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Estación</th>
                            <th>Usuario</th>
                            <th>Período</th>
                            <th>Ventas</th>
                            <th>Retiros</th>
                            <th>Esperado</th>
                            <th>Real</th>
                            <th>Diferencia</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% cierresDeCaja.forEach((cierre) => { %>
                            <% const totalVentasCierre = Number((cierre.ventasEnEfectivo?.montoTotal || 0) + (cierre.ventasEnOtro?.montoTotal || 0)); %>
                            <% const retirosCierre = Number(cierre.egresosManualDinero?.montoTotal || 0); %>
                            <tr>
                                <td data-label="Fecha"><%= cierre.fechaDeCierre ? new Date(cierre.fechaDeCierre).toLocaleString('es-AR') : '—' %></td>
                                <td data-label="Estación"><strong><%= cierre.ubicacionDeEstacion || cierre.estacionDeCobro?.ubicacionDeEstacion || 'Caja' %></strong></td>
                                <td data-label="Usuario"><%= cierre.nombreDelUsuario || '—' %></td>
                                <td data-label="Período"><span class="period-badge"><%= cierre.periodo || 'DIARIO' %></span></td>
                                <td data-label="Ventas"><span class="amount-pill sales">$<%= totalVentasCierre.toFixed(2) %></span></td>
                                <td data-label="Retiros"><span class="amount-pill withdrawals">$<%= retirosCierre.toFixed(2) %></span></td>
                                <td data-label="Esperado"><span class="amount-pill expected">$<%= Number(cierre.dineroEsperado || 0).toFixed(2) %></span></td>
                                <td data-label="Real"><span class="amount-pill cash">$<%= Number(cierre.dineroReal || cierre.dineroEnCaja || 0).toFixed(2) %></span></td>
                                <td data-label="Diferencia">
                                    <span class="difference-pill <%= Number(cierre.diferencia || 0) > 0 ? 'up' : Number(cierre.diferencia || 0) < 0 ? 'down' : 'even' %>">
                                        <%= Number(cierre.diferencia || 0) > 0 ? '+' : '' %>$<%= Number(cierre.diferencia || 0).toFixed(2) %>
                                    </span>
                                </td>
                                <td class="action-cell">
                                    <a href="/administrador/cierres-caja/<%= cierre._id %>" class="btn-primary-modern btn-small cierres-view-btn">👁️ Ver detalle</a>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="empty-state-cierres">
                <div class="empty-icon">🧾</div>
                <h3>No hay cierres para los filtros seleccionados</h3>
                <p>Probá ampliando el rango de fechas o limpiando la búsqueda.</p>
                <a href="/administrador/cierres-caja" class="btn-secondary-modern">Limpiar filtros</a>
            </div>
        <% } %>
    </div>
</div>

<style>
.cierres-filter-bar {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.9rem;
    align-items: end;
    padding: 1rem;
    background: #ffffff;
    border: 1px solid #dbe3f0;
    border-radius: 16px;
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
    margin-bottom: 1.25rem;
}

.filter-label {
    display: block;
    margin-bottom: 0.35rem;
    font-size: 0.88rem;
    font-weight: 700;
    color: #334155;
}

.search-field {
    min-width: 220px;
}

.filter-actions {
    display: flex;
    gap: 0.65rem;
    flex-wrap: wrap;
}

.cierres-filter-submit {
    background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%) !important;
    color: #ffffff !important;
    border: 1px solid rgba(37, 99, 235, 0.35) !important;
    box-shadow: 0 10px 20px rgba(37, 99, 235, 0.18);
}

.cierres-filter-reset {
    background: #f8fafc !important;
    color: #0f172a !important;
    border: 1px solid #cbd5e1 !important;
}

.cierres-summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 1.25rem;
}

.cierres-summary-card {
    background: #ffffff;
    border: 1px solid #dbe3f0;
    border-radius: 16px;
    padding: 1rem 1.1rem;
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
}

.cierres-summary-card.sales-highlight {
    background: linear-gradient(135deg, #ecfdf5 0%, #dcfce7 100%);
    border-color: #86efac;
}

.cierres-summary-card.withdrawals-highlight {
    background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
    border-color: #fdba74;
}

.cierres-summary-card.cash-highlight {
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    border-color: #93c5fd;
}

.cierres-summary-card span {
    display: block;
    margin-bottom: 0.35rem;
    color: #64748b;
    font-size: 0.9rem;
}

.cierres-summary-card strong {
    color: #0f172a;
    font-size: 1.2rem;
}

.cierres-summary-card.sales-highlight strong { color: #166534; }
.cierres-summary-card.withdrawals-highlight strong { color: #9a3412; }
.cierres-summary-card.cash-highlight strong { color: #1d4ed8; }

.cierres-table-shell {
    background: #ffffff;
    border: 1px solid #dbe3f0;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
}

.cierres-table {
    width: 100%;
    border-collapse: collapse;
}

.cierres-table thead {
    background: #eff6ff;
}

.cierres-table th,
.cierres-table td {
    padding: 0.9rem 0.8rem;
    border-bottom: 1px solid #e5e7eb;
    text-align: left;
    vertical-align: middle;
}

.cierres-table th {
    color: #1e3a8a;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
}

.period-badge {
    display: inline-flex;
    padding: 0.28rem 0.55rem;
    border-radius: 999px;
    background: #e0f2fe;
    color: #075985;
    font-weight: 700;
    font-size: 0.78rem;
}

.amount-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.34rem 0.6rem;
    border-radius: 999px;
    font-weight: 800;
    font-size: 0.82rem;
}

.amount-pill.sales { background: #dcfce7; color: #166534; }
.amount-pill.withdrawals { background: #ffedd5; color: #9a3412; }
.amount-pill.expected { background: #ede9fe; color: #6d28d9; }
.amount-pill.cash { background: #dbeafe; color: #1d4ed8; }

.difference-pill {
    display: inline-flex;
    padding: 0.32rem 0.55rem;
    border-radius: 999px;
    font-weight: 800;
    font-size: 0.82rem;
}

.difference-pill.up { background: #dcfce7; color: #166534; }
.difference-pill.down { background: #fee2e2; color: #991b1b; }
.difference-pill.even { background: #e5e7eb; color: #374151; }

.action-cell {
    white-space: nowrap;
}

.btn-small {
    padding: 0.55rem 0.8rem;
    font-size: 0.82rem;
}

.cierres-view-btn {
    background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%) !important;
    color: #ffffff !important;
    border: 1px solid rgba(37, 99, 235, 0.35) !important;
    box-shadow: 0 10px 18px rgba(37, 99, 235, 0.18);
}

.cierres-view-btn:hover {
    background: linear-gradient(135deg, #1d4ed8 0%, #1e3a8a 100%) !important;
}

.empty-state-cierres {
    background: #ffffff;
    border: 1px dashed #cbd5e1;
    border-radius: 16px;
    padding: 2rem 1rem;
    text-align: center;
    color: #475569;
}

.empty-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
}

@media (max-width: 880px) {
    .cierres-table thead {
        display: none;
    }

    .cierres-table,
    .cierres-table tbody,
    .cierres-table tr,
    .cierres-table td {
        display: block;
        width: 100%;
    }

    .cierres-table tr {
        padding: 0.75rem;
        border-bottom: 1px solid #e5e7eb;
    }

    .cierres-table td {
        padding: 0.45rem 0;
        border: none;
    }

    .cierres-table td::before {
        content: attr(data-label) ': ';
        font-weight: 700;
        color: #334155;
    }

    .action-cell {
        padding-top: 0.75rem !important;
    }
}
</style>

<%- include('../partials/footer.ejs'); %>
