<%- include('../partials/headerAdm.ejs'); %>

<div class="admin-dashboard">
    <div class="form-container">
        <!-- Breadcrumb -->
        <nav class="breadcrumb-nav">
            <a href="/administrador" class="breadcrumb-link">Dashboard</a>
            <span class="breadcrumb-separator">/</span>
            <a href="/administrador/buscar" class="breadcrumb-link">Buscar</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current">Editar Producto</span>
        </nav>

        <!-- Form Header -->
        <div class="form-header">
            <h1 class="form-title">✏️ Editar Datos del Producto</h1>
            <p class="form-subtitle">Actualiza la información de "<%= producto.nombre %>"</p>
        </div>

        <!-- Quick Actions -->
        <div class="form-quick-actions">
            <a href="/administrador/productos/<%= producto._id %>/upstockprecio" class="btn-quick-action btn-prices">
                <span class="btn-icon">💰</span>
                Editar Precios
            </a>
            <a href="/administrador/buscar" class="btn-quick-action btn-back">
                <span class="btn-icon">🔍</span>
                Volver al Buscador
            </a>
        </div>

        <!-- Form -->
        <form action="" id="formEdit" class="modern-form">
            <input type="hidden" id="id" value="<%= producto._id %>">

            <div class="form-grid">
                <!-- Información Básica -->
                <div class="form-section">
                    <h3 class="section-title-form">📝 Información Básica</h3>
                    
                    <div class="form-group-modern">
                        <label for="codigoProducto" class="form-label-modern">Código de Barra *</label>
                        <div class="input-with-icon">
                            <span class="input-icon">🔢</span>
                            <input type="text" 
                                   id="codigoProducto" 
                                   name="codigo"
                                   class="form-control-modern with-icon codigoProducto" 
                                   value="<%= producto.codigo %>"
                                   placeholder="Código de barra"
                                   oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                                   required>
                        </div>
                        <small class="form-help">Solo números</small>
                    </div>

                    <div class="form-group-modern">
                        <label for="nombreProducto" class="form-label-modern">Nombre del Producto</label>
                        <div class="input-with-icon">
                            <span class="input-icon">📦</span>
                            <input type="text" 
                                   id="nombreProducto" 
                                   name="nombre"
                                   class="form-control-modern with-icon" 
                                   value="<%= producto.nombre %>"
                                   placeholder="Nombre del producto"
                                   disabled>
                        </div>
                        <small class="form-help">Campo de solo lectura</small>
                    </div>

                    <div class="form-row">
                        <div class="form-group-modern">
                            <label for="marcaProducto" class="form-label-modern">Marca</label>
                            <div class="input-with-icon">
                                <span class="input-icon">🏷️</span>
                                <input type="text" 
                                       id="marcaProducto" 
                                       name="marca"
                                       class="form-control-modern with-icon" 
                                       value="<%= producto.marca %>"
                                       placeholder="Marca"
                                       disabled>
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label for="cantidadProducto" class="form-label-modern">Stock</label>
                            <div class="input-with-icon">
                                <span class="input-icon">📊</span>
                                <input type="text" 
                                       id="cantidadProducto" 
                                       name="cantidad"
                                       class="form-control-modern with-icon" 
                                       value="<%= producto.cantidad %>"
                                       placeholder="0"
                                       disabled>
                            </div>
                        </div>
                    </div>

                    <div class="form-group-modern">
                        <label for="categoriaInterna" class="form-label-modern">Categoría de Góndola</label>
                        <select id="categoriaInterna" 
                                name="categoriaInterna" 
                                class="form-control-modern"
                                disabled>
                            <option value="<%= producto.categoriaInterna %>"><%= producto.categoriaInterna %></option>
                            <option value="varios">VARIOS</option>
                            <option value="aceite/vinagre">Aceite/Vinagre/Embotellados</option>
                            <option value="arroz">Arroz</option>
                            <option value="articulos del hogar">Artículos de hogar</option>
                            <option value="articulos de limpieza">Artículos de limpieza</option>
                            <option value="azucar">Azúcar</option>
                            <option value="bebidas con alcohol">Bebidas con Alcohol</option>
                            <option value="bebidas sin alcohol">Bebidas sin Alcohol</option>
                            <option value="enlatados">Enlatados</option>
                            <option value="fideos">Fideos</option>
                            <option value="fiambreria">Fiambrería</option>
                            <option value="pañales">Pañales</option>
                            <option value="galletitas">Galletitas</option>
                            <option value="golosinas">Golosinas</option>
                            <option value="higene corporal">Higiene corporal</option>
                            <option value="higene femenina">Higiene femenina</option>
                            <option value="panaderia">Panadería</option>
                            <option value="no perecederos">No perecederos</option>
                            <option value="te cafe">Té/Café</option>
                            <option value="sal">Sal</option>
                            <option value="verduleria">Verdulería</option>
                            <option value="yerba">Yerba</option>
                        </select>
                    </div>
                </div>

                <!-- Precios (Solo lectura) -->
                <div class="form-section">
                    <h3 class="section-title-form">💰 Precios (Solo Lectura)</h3>
                    
                    <div class="form-row">
                        <div class="form-group-modern">
                            <label for="precioMinorista" class="form-label-modern">Precio Minorista</label>
                            <div class="input-with-icon">
                                <span class="input-icon">$</span>
                                <input type="text" 
                                       id="precioMinorista" 
                                       name="precioMinorista"
                                       class="form-control-modern with-icon" 
                                       value="<%= producto.precioMinorista %>"
                                       disabled>
                            </div>
                            <small class="form-help">Edita en la sección de precios</small>
                        </div>

                        <div class="form-group-modern">
                            <label for="precioMayorista" class="form-label-modern">Precio Mayorista</label>
                            <div class="input-with-icon">
                                <span class="input-icon">$</span>
                                <input type="text" 
                                       id="precioMayorista" 
                                       name="precioMayorista"
                                       class="form-control-modern with-icon" 
                                       value="<%= producto.precioMayorista %>"
                                       disabled>
                            </div>
                        </div>
                    </div>

                    <div class="form-group-modern">
                        <label for="precioCosto" class="form-label-modern">Precio Costo</label>
                        <div class="input-with-icon">
                            <span class="input-icon">$</span>
                            <input type="text" 
                                   id="precioCosto" 
                                   name="precioCosto"
                                   class="form-control-modern with-icon" 
                                   value="<%= producto.precioCosto %>"
                                   disabled>
                        </div>
                    </div>
                </div>

                <!-- Información Adicional -->
                <div class="form-section">
                    <h3 class="section-title-form">📋 Información Adicional</h3>
                    
                    <div class="form-row">
                        <div class="form-group-modern">
                            <label for="peso" class="form-label-modern">Peso (KG/Gramos)</label>
                            <div class="input-with-icon">
                                <span class="input-icon">⚖️</span>
                                <input type="text" 
                                       id="peso" 
                                       name="peso"
                                       class="form-control-modern with-icon" 
                                       value="<%= producto.peso || '' %>"
                                       placeholder="Peso"
                                       disabled>
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label for="fechaDeVencimiento" class="form-label-modern">Fecha de Vencimiento</label>
                            <div class="input-with-icon">
                                <span class="input-icon">📅</span>
                                <input type="text" 
                                       id="fechaDeVencimiento" 
                                       name="fechaDeVencimiento"
                                       class="form-control-modern with-icon" 
                                       value="<%= producto.fechaDeVencimiento || '' %>"
                                       placeholder="Fecha"
                                       disabled>
                            </div>
                        </div>
                    </div>

                    <div class="form-group-modern">
                        <label for="impuesto" class="form-label-modern">Impuesto Aplicado</label>
                        <select id="impuesto" 
                                name="impuesto"
                                class="form-control-modern"
                                disabled>
                            <option value="<%= producto.impuestoAplicado %>"><%= producto.impuestoAplicado %>%</option>
                            <option value="0">0%</option>
                            <option value="8">8%</option>
                            <option value="21">21%</option>
                            <option value="35">35%</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
                <a href="/administrador/buscar" class="btn-secondary-modern">
                    ← Volver al buscador
                </a>
                <button type="submit" id="editGuar" class="btn-primary-modern btn-save-emphasis">
                    <span class="btn-icon">✏️</span>
                    Habilitar edición
                </button>
            </div>
        </form>
    </div>
</div>

<style>
.form-quick-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
}

.btn-quick-action {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1rem;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 700;
    box-shadow: 0 10px 22px rgba(15, 23, 42, 0.08);
}

.btn-prices {
    background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    color: #ffffff;
}

.btn-back {
    background: #e5e7eb;
    color: #111827;
    border: 1px solid #cbd5e1;
}

.modern-form {
    background: #ffffff;
    border: 1px solid #dbe3f0;
    border-radius: 18px;
    box-shadow: 0 16px 30px rgba(15, 23, 42, 0.06);
}

.form-section {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 1.15rem;
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.04);
}

.form-control-modern,
select.form-control-modern,
input.form-control-modern {
    background: #ffffff !important;
    color: #0f172a !important;
    border: 1px solid #cbd5e1 !important;
    -webkit-text-fill-color: #0f172a;
    box-shadow: none;
}

.form-control-modern:disabled,
select.form-control-modern:disabled,
input.form-control-modern:disabled {
    background: #f8fafc !important;
    color: #334155 !important;
    opacity: 1;
}

.form-control-modern::placeholder {
    color: #94a3b8;
}

.form-control-modern:focus,
select.form-control-modern:focus,
input.form-control-modern:focus {
    border-color: #2563eb !important;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12) !important;
    outline: none;
}

.input-with-icon {
    position: relative;
}

.input-icon {
    position: absolute;
    left: 0.85rem;
    top: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 999px;
    background: #eff6ff;
    color: #1d4ed8;
    font-size: 0.95rem;
}

.form-control-modern.with-icon {
    padding-left: 3rem;
}

.form-actions .btn-primary-modern,
.form-actions .btn-secondary-modern {
    box-shadow: 0 10px 22px rgba(15, 23, 42, 0.08);
}

.form-actions .btn-secondary-modern {
    background: #e5e7eb;
    color: #111827;
    border: 1px solid #cbd5e1;
}
</style>

<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="../../../editPage.js"></script>

<%- include('../partials/footer.ejs'); %>
