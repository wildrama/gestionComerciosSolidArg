<%- include('./partials/headerAdm.ejs'); %>

<%- include('./partials/flash.ejs'); %>

<div class="admin-dashboard">
    <div class="form-container">
        <!-- Breadcrumb -->
        <nav class="breadcrumb-nav">
            <a href="/administrador" class="breadcrumb-link">Dashboard</a>
            <span class="breadcrumb-separator">/</span>
            <a href="/administrador/productos" class="breadcrumb-link">Productos</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current">Editar</span>
        </nav>

        <!-- Form Header -->
        <div class="form-header">
            <h1 class="form-title">✏️ Editar Producto</h1>
            <p class="form-subtitle">Modifica la información del producto "<%= producto.nombre %>"</p>
        </div>

        <!-- Form -->
        <form action="/administrador/productos/editar/<%= producto._id %>?_method=PUT" 
              method="POST" 
              enctype="multipart/form-data" 
              class="modern-form">
            
            <div class="form-grid">
                <!-- Información Básica -->
                <div class="form-section">
                    <h3 class="section-title-form">📝 Información Básica</h3>
                    
                    <div class="form-group-modern">
                        <label for="nombre" class="form-label-modern">
                            Nombre del Producto <span class="required">*</span>
                        </label>
                        <input type="text" 
                               id="nombre" 
                               name="nombre" 
                               class="form-control-modern" 
                               value="<%= producto.nombre %>"
                               required>
                    </div>

                    <div class="form-row">
                        <div class="form-group-modern">
                            <label for="categoria" class="form-label-modern">
                                Categoría <span class="required">*</span>
                            </label>
                            <select id="categoria" name="categoria" class="form-control-modern" required>
                                <option value="">Selecciona una categoría</option>
                                <option value="Electrónica" <%= producto.categoria === 'Electrónica' ? 'selected' : '' %>>Electrónica</option>
                                <option value="Ropa" <%= producto.categoria === 'Ropa' ? 'selected' : '' %>>Ropa</option>
                                <option value="Alimentos" <%= producto.categoria === 'Alimentos' ? 'selected' : '' %>>Alimentos</option>
                                <option value="Hogar" <%= producto.categoria === 'Hogar' ? 'selected' : '' %>>Hogar</option>
                                <option value="Deportes" <%= producto.categoria === 'Deportes' ? 'selected' : '' %>>Deportes</option>
                                <option value="Libros" <%= producto.categoria === 'Libros' ? 'selected' : '' %>>Libros</option>
                                <option value="Juguetes" <%= producto.categoria === 'Juguetes' ? 'selected' : '' %>>Juguetes</option>
                                <option value="Otros" <%= producto.categoria === 'Otros' ? 'selected' : '' %>>Otros</option>
                            </select>
                        </div>

                        <div class="form-group-modern">
                            <label for="codigo" class="form-label-modern">Código/SKU</label>
                            <input type="text" 
                                   id="codigo" 
                                   name="codigo" 
                                   class="form-control-modern"
                                   value="<%= producto.codigo || '' %>">
                        </div>
                    </div>
                </div>

                <!-- Precio e Inventario -->
                <div class="form-section">
                    <h3 class="section-title-form">💰 Precio e Inventario</h3>
                    
                    <div class="form-row">
                        <div class="form-group-modern">
                            <label for="precio" class="form-label-modern">
                                Precio <span class="required">*</span>
                            </label>
                            <div class="input-with-icon">
                                <span class="input-icon">$</span>
                                <input type="number" 
                                       id="precio" 
                                       name="precio" 
                                       class="form-control-modern with-icon" 
                                       step="0.01"
                                       min="0"
                                       value="<%= producto.precio %>"
                                       required>
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label for="stock" class="form-label-modern">
                                Stock <span class="required">*</span>
                            </label>
                            <div class="input-with-icon">
                                <span class="input-icon">📦</span>
                                <input type="number" 
                                       id="stock" 
                                       name="stock" 
                                       class="form-control-modern with-icon" 
                                       min="0"
                                       value="<%= producto.stock %>"
                                       required>
                            </div>
                        </div>
                    </div>

                    <% if (producto.stock < 10) { %>
                    <div class="alert-warning">
                        <span class="alert-icon">⚠️</span>
                        <span>Este producto tiene stock bajo. Considera reabastecerlo pronto.</span>
                    </div>
                    <% } %>
                </div>

                <!-- Imagen -->
                <div class="form-section">
                    <h3 class="section-title-form">🖼️ Imagen del Producto</h3>
                    
                    <% if (producto.imagen) { %>
                    <div class="current-image">
                        <p class="form-label-modern">Imagen actual:</p>
                        <img src="<%= producto.imagen %>" alt="<%= producto.nombre %>" class="preview-img">
                    </div>
                    <% } %>
                    
                    <div class="form-group-modern">
                        <label for="imagen" class="form-label-modern">Cambiar Imagen (opcional)</label>
                        <div class="file-upload-wrapper">
                            <input type="file" 
                                   id="imagen" 
                                   name="imagen" 
                                   class="file-input" 
                                   accept="image/*"
                                   onchange="previewImage(event)">
                            <label for="imagen" class="file-label">
                                <span class="file-icon">📁</span>
                                <span class="file-text">Seleccionar nueva imagen</span>
                            </label>
                        </div>
                        
                        <div id="imagePreview" class="image-preview"></div>
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
                <a href="/administrador/productos" class="btn-secondary-modern">
                    ← Volver a productos
                </a>
                <button type="submit" class="btn-primary-modern">
                    <span class="btn-icon">💾</span>
                    Guardar cambios
                </button>
            </div>
        </form>
    </div>
</div>

<style>
.edit-product-page .form-container,
.admin-dashboard .form-container {
    max-width: 1100px;
}

.modern-form {
    background: #ffffff;
    border: 1px solid #dbe3f0;
    border-radius: 18px;
    box-shadow: 0 16px 30px rgba(15, 23, 42, 0.06);
}

.form-section {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 1.15rem;
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.04);
}

.form-control-modern,
select.form-control-modern,
input.form-control-modern {
    background: #ffffff !important;
    color: #0f172a !important;
    border: 1px solid #cbd5e1 !important;
    -webkit-text-fill-color: #0f172a;
    box-shadow: none;
}

.form-control-modern::placeholder {
    color: #94a3b8;
}

.form-control-modern:focus,
select.form-control-modern:focus,
input.form-control-modern:focus {
    border-color: #2563eb !important;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12) !important;
    outline: none;
}

.input-with-icon {
    position: relative;
}

.input-icon {
    position: absolute;
    left: 0.85rem;
    top: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 999px;
    background: #eff6ff;
    color: #1d4ed8;
    font-size: 0.95rem;
}

.form-control-modern.with-icon {
    padding-left: 3rem;
}

.alert-warning {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 1rem;
    padding: 0.85rem 1rem;
    border-radius: 12px;
    background: #fff7ed;
    color: #9a3412;
    border: 1px solid #fed7aa;
}

.current-image {
    margin-bottom: 1rem;
    padding: 0.9rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
}

.preview-img {
    display: block;
    max-width: 160px;
    border-radius: 12px;
    border: 1px solid #cbd5e1;
}

.file-input {
    display: none;
}

.file-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1rem;
    background: #f8fafc;
    color: #0f172a;
    border: 1px dashed #94a3b8;
    border-radius: 12px;
    cursor: pointer;
}

.file-label:hover {
    background: #eff6ff;
    border-color: #60a5fa;
}

.form-actions .btn-secondary-modern {
    background: #e5e7eb;
    color: #111827;
    border: 1px solid #cbd5e1;
}

.form-actions .btn-primary-modern,
.form-actions .btn-secondary-modern {
    box-shadow: 0 10px 22px rgba(15, 23, 42, 0.08);
}

.preview-container {
    position: relative;
    display: inline-block;
    margin-top: 0.75rem;
}

.preview-remove {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    border: none;
    background: rgba(15, 23, 42, 0.75);
    color: #ffffff;
    cursor: pointer;
}
</style>

<script>
function previewImage(event) {
    const preview = document.getElementById('imagePreview');
    const file = event.target.files[0];
    const fileText = document.querySelector('.file-text');
    
    if (file) {
        if (file.size > 5 * 1024 * 1024) {
            alert('El archivo es muy grande. Máximo 5MB');
            event.target.value = '';
            return;
        }
        
        fileText.textContent = file.name;
        const reader = new FileReader();
        
        reader.onload = function(e) {
            preview.innerHTML = `
                <div class="preview-container">
                    <p class="form-label-modern">Nueva imagen:</p>
                    <img src="${e.target.result}" alt="Preview" class="preview-img">
                    <button type="button" class="preview-remove" onclick="removeImage()">✕</button>
                </div>
            `;
        }
        
        reader.readAsDataURL(file);
    }
}

function removeImage() {
    document.getElementById('imagen').value = '';
    document.getElementById('imagePreview').innerHTML = '';
    document.querySelector('.file-text').textContent = 'Seleccionar nueva imagen';
}
</script>

<%- include('./partials/footer.ejs'); %>
