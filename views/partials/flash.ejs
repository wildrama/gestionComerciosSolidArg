<%
const successMessages = Array.isArray(success) ? success.filter(Boolean) : (success ? [success] : []);
const errorMessages = Array.isArray(error) ? error.filter(Boolean) : (error ? [error] : []);
const hasFlashMessages = successMessages.length || errorMessages.length;
%>
<% if (!locals.__flashRendered && hasFlashMessages) { %>
<% locals.__flashRendered = true; %>
<div class="flash-stack" data-flash-stack>
    <% successMessages.forEach((message) => { %>
        <div class="app-flash app-flash-success" role="status" aria-live="polite" data-autohide="true">
            <div class="app-flash-icon">✅</div>
            <div class="app-flash-copy">
                <strong class="app-flash-title">Listo</strong>
                <p class="app-flash-text"><%= message %></p>
            </div>
            <button type="button" class="app-flash-close" data-flash-close aria-label="Cerrar mensaje">×</button>
        </div>
    <% }) %>

    <% errorMessages.forEach((message) => { %>
        <div class="app-flash app-flash-error" role="alert" aria-live="assertive">
            <div class="app-flash-icon">⚠️</div>
            <div class="app-flash-copy">
                <strong class="app-flash-title">Revisá esto</strong>
                <p class="app-flash-text"><%= message %></p>
            </div>
            <button type="button" class="app-flash-close" data-flash-close aria-label="Cerrar mensaje">×</button>
        </div>
    <% }) %>
</div>

<style>
.flash-stack {
    max-width: 1180px;
    margin: 1rem auto 0;
    padding: 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}
.app-flash {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    padding: 0.85rem 1rem;
    border-radius: 14px;
    border: 1px solid #dbe3f0;
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    background: #ffffff;
}
.app-flash-success {
    background: linear-gradient(135deg, #ecfdf5 0%, #f0fdf4 100%);
    border-color: #86efac;
}
.app-flash-error {
    background: linear-gradient(135deg, #fff1f2 0%, #fff7ed 100%);
    border-color: #fca5a5;
}
.app-flash-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
    background: rgba(255,255,255,0.72);
}
.app-flash-copy {
    flex: 1;
    min-width: 0;
}
.app-flash-title {
    display: block;
    margin-bottom: 0.15rem;
    color: #0f172a;
    font-size: 0.95rem;
}
.app-flash-text {
    margin: 0;
    color: #334155;
    line-height: 1.4;
}
.app-flash-close {
    border: none;
    background: transparent;
    color: #64748b;
    font-size: 1.15rem;
    cursor: pointer;
    line-height: 1;
    padding: 0.1rem;
}
.app-flash-close:hover {
    color: #0f172a;
}
</style>

<script>
(function () {
    const stack = document.querySelector('[data-flash-stack]');
    if (!stack) return;

    stack.querySelectorAll('[data-flash-close]').forEach((button) => {
        button.addEventListener('click', () => {
            const flash = button.closest('.app-flash');
            if (flash) flash.remove();
        });
    });

    window.setTimeout(() => {
        stack.querySelectorAll('[data-autohide="true"]').forEach((flash) => flash.remove());
    }, 4500);
})();
</script>
<% } %>