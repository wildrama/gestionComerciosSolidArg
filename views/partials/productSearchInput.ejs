<!-- PRODUCT SEARCH INPUT - Componente reutilizable -->

<div class="product-search-widget">
    <!-- Input de búsqueda -->
    <div class="search-input-wrapper mb-2">
        <div class="input-group modern-search-group">
            <span class="input-group-text">🔍</span>
            <input type="text" 
                   id="<%= inputId || 'productSearchInput' %>" 
                   class="form-control product-search-control" 
                   placeholder="Buscar por nombre, marca o código"
                   autocomplete="off">
            <button type="button" 
                    class="btn btn-outline-secondary product-search-clear"
                    id="<%= inputId %>_clear"
                    style="display: none;">
                ✕
            </button>
        </div>
        <small class="product-search-help">Escribí al menos un dato del producto para encontrarlo rápido.</small>
    </div>

    <!-- Dropdown de resultados -->
    <div id="<%= resultsId || 'productSearchResults' %>" 
         class="product-search-dropdown"
         style="display: none;">
    </div>

    <!-- Hidden input para producto seleccionado -->
    <input type="hidden" 
           id="<%= selectedProductId || 'selectedProductId' %>" 
           name="productId">
    
    <!-- Info del producto seleccionado -->
    <div id="<%= selectedProductId || 'selectedProductId' %>_info" 
         class="product-info-selected"
         style="display: none;">
    </div>
</div>

<style>
.product-search-widget {
    position: relative;
    width: 100%;
}

.search-input-wrapper {
    position: relative;
}

.modern-search-group {
    display: flex;
    align-items: stretch;
    background: #ffffff;
    border: 1px solid #cbd5e1;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 10px 22px rgba(15, 23, 42, 0.06);
}

.input-group-text {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 48px;
    background: #eff6ff;
    color: #1d4ed8;
    font-size: 1rem;
    border-right: 1px solid #dbeafe;
}

.product-search-control {
    flex: 1;
    border: none !important;
    box-shadow: none !important;
    padding: 0.9rem 1rem;
    font-size: 1rem;
    background: #ffffff !important;
    color: #0f172a !important;
}

.product-search-control::placeholder {
    color: #94a3b8;
}

.product-search-clear {
    border: none;
    background: #f8fafc;
    color: #475569;
    padding: 0 0.95rem;
    font-weight: 700;
    cursor: pointer;
}

.product-search-help {
    display: block;
    margin-top: 0.45rem;
    color: #64748b;
    font-size: 0.84rem;
}

.product-search-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    right: 0;
    background: #ffffff;
    border: 1px solid #dbe3f0;
    border-radius: 14px;
    max-height: 320px;
    overflow-y: auto;
    z-index: 1000;
    box-shadow: 0 18px 30px rgba(15, 23, 42, 0.12);
}

.product-search-item {
    padding: 0.85rem 1rem;
    cursor: pointer;
    border-bottom: 1px solid #eef2f7;
    transition: background-color 0.15s ease;
}

.product-search-item:hover {
    background-color: #f8fbff;
}

.product-search-item:last-child {
    border-bottom: none;
}

.product-search-name {
    font-weight: 700;
    color: #0f172a;
}

.product-search-meta {
    font-size: 0.85rem;
    color: #64748b;
    margin-top: 0.2rem;
}

.product-search-item.state-item {
    color: #475569;
}

.product-info-selected {
    padding: 1rem;
    background: linear-gradient(135deg, #eff6ff 0%, #ffffff 100%);
    border: 1px solid #bfdbfe;
    border-radius: 12px;
    margin-top: 0.75rem;
}

.product-info-name {
    font-weight: 700;
    color: #1d4ed8;
}

.product-info-details {
    font-size: 0.9rem;
    color: #475569;
    margin-top: 0.25rem;
}
</style>

<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/searchManager.js"></script>

<script>
(function() {
    const inputId = '<%= inputId ? inputId : "productSearchInput" %>';
    const resultsId = '<%= resultsId ? resultsId : "productSearchResults" %>';
    const selectedProductId = '<%= selectedProductId ? selectedProductId : "selectedProductId" %>';

    const input = document.getElementById(inputId);
    const resultsDiv = document.getElementById(resultsId);
    const selectedInput = document.getElementById(selectedProductId);
    const selectedInfo = document.getElementById(selectedProductId + '_info');
    const clearBtn = document.getElementById(inputId + '_clear');

    // Crear gestor de búsqueda
    const searchManager = new SearchManager({
        endpoint: '/api/search/smart',
        debounceDelay: 300,
        minChars: 1,
        onSuccess: (productos) => {
            displayResults(productos);
        },
        onError: (message) => {
            resultsDiv.innerHTML = '<div class="product-search-item state-item">' + (message || 'Error en la búsqueda') + '</div>';
            resultsDiv.style.display = 'block';
        },
        onLoading: (isLoading) => {
            if (isLoading) {
                resultsDiv.innerHTML = '<div class="product-search-item state-item">⏳ Buscando productos...</div>';
                resultsDiv.style.display = 'block';
            }
        }
    });

    // Input focus y cambio
    input.addEventListener('input', function() {
        const value = this.value.trim();
        
        if (value.length === 0) {
            resultsDiv.style.display = 'none';
            clearBtn.style.display = 'none';
            return;
        }

        clearBtn.style.display = 'block';
        searchManager.search(value);
    });

    // Clear button
    clearBtn.addEventListener('click', function() {
        input.value = '';
        resultsDiv.style.display = 'none';
        clearBtn.style.display = 'none';
        selectedInput.value = '';
        selectedInfo.style.display = 'none';
        searchManager.clear();
        input.focus();
    });

    // Cerrar resultados al hacer click fuera
    document.addEventListener('click', function(e) {
        if (!input.contains(e.target) && !resultsDiv.contains(e.target)) {
            resultsDiv.style.display = 'none';
        }
    });

    // Enter para búsqueda inmediata
    input.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            searchManager.searchNow(this.value);
        }
    });

    // Mostrar resultados
    function displayResults(productos) {
        resultsDiv.innerHTML = '';

        if (!productos || productos.length === 0) {
            resultsDiv.innerHTML = '<div class="product-search-item state-item">No se encontraron productos</div>';
            resultsDiv.style.display = 'block';
            return;
        }

        productos.forEach(producto => {
            const item = document.createElement('div');
            item.className = 'product-search-item';
            item.innerHTML = `
                <div class="product-search-name">${producto.nombre}</div>
                <div class="product-search-meta">
                    ${producto.marca || 'Sin marca'} • Código: ${producto.codigo || 'N/A'} • $${(producto.precioMinorista || 0).toFixed(2)}
                </div>
            `;
            
            item.addEventListener('click', () => selectProduct(producto));
            resultsDiv.appendChild(item);
        });

        resultsDiv.style.display = 'block';
    }

    // Seleccionar producto
    function selectProduct(producto) {
        input.value = producto.nombre;
        selectedInput.value = producto._id;
        resultsDiv.style.display = 'none';
        clearBtn.style.display = 'block';
        searchManager.clear();

        // Mostrar info del producto seleccionado
        selectedInfo.innerHTML = `
            <div class="product-info-name">${producto.nombre}</div>
            <div class="product-info-details">
                Marca: ${producto.marca || 'N/A'} | 
                Código: ${producto.codigo || 'N/A'} | 
                Stock: ${producto.cantidad || 0} | 
                Precio: $${(producto.precioMinorista || 0).toFixed(2)}
            </div>
        `;
        selectedInfo.style.display = 'block';

        // Disparar evento personalizado
        const event = new CustomEvent('productSelected', { 
            detail: { producto, inputId, selectedProductId } 
        });
        document.dispatchEvent(event);
    }
})();
</script>
