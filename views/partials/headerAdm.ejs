<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel Administrador - SOLIDARG-COMERCIOS</title>
    <link rel="stylesheet" href="/styles/app-unified.css">
</head>
<body class="admin-page">
    <a class="skip-link" href="#admin-main-content">Saltar al contenido principal</a>

    <!-- Navbar Principal -->
    <nav class="navbar-admin" aria-label="Navegación principal del administrador">
        <div class="navbar-content">
            <a href="/administrador" class="navbar-brand" aria-label="Volver al inicio del panel administrador">
                <span class="brand-icon">🏪</span>
                <span class="brand-text">SOLIDARG-COMERCIOS</span>
            </a>
            <button
                id="navbarToggle"
                class="navbar-toggle"
                type="button"
                aria-expanded="false"
                aria-controls="navbarMenu"
                aria-label="Abrir menú principal">
                <span aria-hidden="true">☰</span>
            </button>
            <div class="navbar-menu" id="navbarMenu">
                <a href="/administrador" class="nav-link">
                    <span class="nav-icon">🏠</span>
                    <span>Inicio</span>
                </a>
                <a href="/administrador/productos" class="nav-link">
                    <span class="nav-icon">📦</span>
                    <span>Stock</span>
                </a>
                <a href="/administrador/buscar" class="nav-link">
                    <span class="nav-icon">🔍</span>
                    <span>Buscar</span>
                </a>
                <a href="/administrador/ofertas" class="nav-link">
                    <span class="nav-icon">🎁</span>
                    <span>Ofertas</span>
                </a>
                <a href="/administrador/estacionesdecobro" class="nav-link">
                    <span class="nav-icon">💰</span>
                    <span>Estaciones</span>
                </a>
                <a href="/administrador/cierres-caja" class="nav-link">
                    <span class="nav-icon">🧾</span>
                    <span>Cierres</span>
                </a>
                <a href="/cerrar-sesion" class="nav-link nav-link-logout">
                    <span class="nav-icon">🚪</span>
                    <span>Salir</span>
                </a>
            </div>
        </div>
    </nav>

    <!-- Submenú de Acceso Rápido -->
    <div class="submenu-container" role="navigation" aria-label="Accesos frecuentes del administrador">
        <div class="submenu-quick-access">
            <p class="submenu-title">⚡ Accesos frecuentes</p>
            <ul class="submenu-links">
                <li>
                    <a href="/administrador/productos" class="submenu-link">
                        <span class="submenu-link-icon">📦</span>
                        Ver stock
                    </a>
                </li>
                <li>
                    <a href="/administrador/productos/nuevo#codigo" class="submenu-link">
                        <span class="submenu-link-icon">➕</span>
                        Nuevo producto
                    </a>
                </li>
                <li>
                    <a href="/administrador/buscar" class="submenu-link">
                        <span class="submenu-link-icon">🔍</span>
                        Buscar
                    </a>
                </li>
                <li>
                    <a href="/administrador/ofertas" class="submenu-link">
                        <span class="submenu-link-icon">🎁</span>
                        Ofertas
                    </a>
                </li>
                <li>
                    <a href="/administrador/estacionesdecobro" class="submenu-link">
                        <span class="submenu-link-icon">💰</span>
                        Estaciones
                    </a>
                </li>
                <li>
                    <a href="/administrador/cierres-caja" class="submenu-link">
                        <span class="submenu-link-icon">🧾</span>
                        Cierres
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <!-- Flash Messages -->
    <%- include('../partials/flash.ejs'); %>
    <script src="/js/admin-ui.js" defer></script>


