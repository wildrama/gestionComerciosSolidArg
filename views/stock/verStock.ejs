<%- include('../partials/headerAdm.ejs'); %>

<div class="admin-dashboard" id="admin-main-content">
    <!-- Header -->
    <div class="page-header">
        <div class="page-header-content">
            <div>
                <h1 class="page-title">📊 Gestión de Stock</h1>
                <p class="page-subtitle">Total de productos: <%= cantidadTotalDeProductos %></p>
            </div>
            <div class="page-actions stock-page-actions">
                <a href="/administrador/productos/imprimir-codigos" class="btn-secondary-modern btn-offers-entry" target="_blank" rel="noopener">
                    <span class="btn-icon">🖨️</span>
                    Imprimir códigos
                </a>
                <a href="/administrador/productos/nuevo" class="btn-primary-modern btn-save-emphasis btn-stock-main-action">
                    <span class="btn-icon">➕</span>
                    Agregar producto
                </a>
            </div>
        </div>
    </div>

    <!-- Stats Mini -->
    <div class="stock-stats-mini">
        <div class="stock-stat-card">
            <div class="stock-stat-icon stat-theme-primary">📦</div>
            <div class="stock-stat-content">
                <h3><%= cantidadTotalDeProductos %></h3>
                <p>Total Productos</p>
            </div>
        </div>
        <div class="stock-stat-card">
            <div class="stock-stat-icon stat-theme-success">✓</div>
            <div class="stock-stat-content">
                <h3><%= stockTotalGeneral %></h3>
                <p>Stock Total</p>
            </div>
        </div>
        <div class="stock-stat-card">
            <div class="stock-stat-icon stat-theme-warning">⚠️</div>
            <div class="stock-stat-content">
                <h3><%= stockBajoCount %></h3>
                <p>Stock Bajo</p>
            </div>
        </div>
    </div>

    <div class="stock-filters-card stock-quick-start">
        <div class="scanner-guide-copy">
            <span class="scanner-badge">Carga recomendada</span>
            <h3>📷 Alta orientada a lector de código</h3>
            <p>Al cargar un <strong>producto nuevo</strong>, primero escaneá su código de barras. Si el artículo no trae código —por ejemplo <strong>fiambre</strong>, <strong>pan por medio kilo</strong> o productos fraccionados— usá <strong>Generar código</strong> para crear uno nuevo y seguir con la carga.</p>
        </div>
        <div class="scanner-guide-actions">
            <a href="/administrador/productos/nuevo" class="btn-primary-modern btn-save-emphasis btn-stock-main-action">
                <span class="btn-icon">🚀</span>
                Cargar producto ahora
            </a>
        </div>
    </div>

    <!-- Filtros y Búsqueda -->
    <div class="stock-filters-card">
        <div class="filters-row-stock">
            <div class="search-box">
                <label for="searchStock" class="sr-only">Buscar productos por nombre, marca o categoría</label>
                <span class="search-icon" aria-hidden="true">🔍</span>
                <input type="text" 
                       id="searchStock" 
                       placeholder="Buscar por nombre, marca o categoría..." 
                       class="search-input"
                       aria-label="Buscar productos por nombre, marca o categoría"
                       autocomplete="off"
                       inputmode="search"
                       enterkeyhint="search"
                       oninput="filtrarStock()">
            </div>
            <div class="filter-group-stock">
                <div class="filter-group">
                    <label for="filterCategoria" class="sr-only">Filtrar productos por categoría</label>
                    <select id="filterCategoria" class="filter-select" aria-label="Filtrar productos por categoría" onchange="filtrarStock()">
                        <option value="">Todas las categorías</option>
                        <% (categorias || []).forEach(cat => { %>
                            <option value="<%= cat %>"><%= cat %></option>
                        <% }); %>
                    </select>
                </div>
                <div class="filter-group">
                    <label for="filterStock" class="sr-only">Filtrar productos por nivel de stock</label>
                    <select id="filterStock" class="filter-select" aria-label="Filtrar productos por nivel de stock" onchange="filtrarStock()">
                        <option value="">Todo el stock</option>
                        <option value="bajo">Stock bajo (&lt;10)</option>
                        <option value="medio">Stock medio (10-50)</option>
                        <option value="alto">Stock alto (&gt;50)</option>
                    </select>
                </div>
                <button type="button" onclick="limpiarFiltros()" class="btn-filter-clear" aria-label="Limpiar búsqueda y filtros">🔄 Limpiar</button>
            </div>
        </div>
    </div>

    <!-- Vista Desktop: Tabla -->
    <div class="stock-table-desktop">
        <div class="stock-table-wrapper">
            <table class="stock-table" aria-label="Listado general de stock">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Marca</th>
                        <th style="text-align: center;">Stock</th>
                        <th>Precio Minorista</th>
                        <th>Precio Mayorista</th>
                        <th>Categoría</th>
                        <th>Presentación</th>
                        <th style="text-align: center;">Acciones</th>
                    </tr>
                </thead>
                <tbody id="stockTableBody">
                    <% productos.forEach(producto => { %>
                    <tr class="stock-row" 
                        data-nombre="<%= producto.nombre.toLowerCase() %>"
                        data-marca="<%= (producto.marca || '').toLowerCase() %>"
                        data-categoria="<%= (producto.categoriaInterna || '').toLowerCase() %>"
                        data-stock="<%= producto.cantidad || 0 %>">
                        <td>
                            <div class="stock-product-cell">
                                <div class="stock-product-placeholder">📦</div>
                                <div class="stock-product-info">
                                    <h4><%= producto.nombre %></h4>
                                    <% if (producto.peso) { %>
                                        <p><%= producto.peso %></p>
                                    <% } %>
                                </div>
                            </div>
                        </td>
                        <td><%= producto.marca || '-' %></td>
                        <td style="text-align: center;">
                            <span class="stock-number <%= producto.cantidad < 10 ? 'low' : (producto.cantidad < 50 ? 'ok' : 'high') %>">
                                <%= producto.cantidad || 0 %>
                            </span>
                        </td>
                        <td><strong style="color: #6366f1;">$<%= producto.precioMinorista ? producto.precioMinorista.toFixed(2) : '0.00' %></strong></td>
                        <td><strong style="color: #10b981;">$<%= producto.precioMayorista ? producto.precioMayorista.toFixed(2) : '0.00' %></strong></td>
                        <td><%= producto.categoriaInterna || '-' %></td>
                        <td><%= producto.presentacion || '-' %></td>
                        <td style="text-align: center;">
                            <div class="stock-actions">
                                <a href="/administrador/productos/<%= producto._id %>/upstock" 
                                   class="btn-stock-action is-stock" 
                                   title="Actualizar stock">
                                    <span>📦</span><span>Stock</span>
                                </a>
                                <a href="/administrador/productos/<%= producto._id %>" 
                                   class="btn-stock-action is-view" 
                                   title="Ver detalles">
                                    <span>🔎</span><span>Ver</span>
                                </a>
                                <a href="/administrador/productos/imprimir-codigos?ids=<%= producto._id %>" 
                                   class="btn-stock-action is-print" 
                                   title="Imprimir código" target="_blank" rel="noopener">
                                    <span>🖨️</span><span>Código</span>
                                </a>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Vista Mobile: Cards -->
    <div class="stock-cards-mobile" id="stockCardsMobile">
        <% productos.forEach(producto => { %>
        <div class="stock-card-mobile" 
             data-nombre="<%= producto.nombre.toLowerCase() %>"
             data-marca="<%= (producto.marca || '').toLowerCase() %>"
             data-categoria="<%= (producto.categoriaInterna || '').toLowerCase() %>"
             data-stock="<%= producto.cantidad || 0 %>">
            <div class="stock-card-header-mobile">
                <div class="stock-card-icon">📦</div>
                <div>
                    <h3 class="stock-card-title"><%= producto.nombre %></h3>
                    <p class="stock-card-subtitle"><%= producto.marca || 'Sin marca' %></p>
                </div>
            </div>
            <div class="stock-card-body-mobile">
                <div class="stock-card-row">
                    <span class="label">Stock:</span>
                    <span class="value stock-value <%= producto.cantidad < 10 ? 'low' : 'ok' %>">
                        <%= producto.cantidad || 0 %> unidades
                    </span>
                </div>
                <div class="stock-card-row">
                    <span class="label">Precio Minorista:</span>
                    <span class="value price">$<%= producto.precioMinorista ? producto.precioMinorista.toFixed(2) : '0.00' %></span>
                </div>
                <div class="stock-card-row">
                    <span class="label">Precio Mayorista:</span>
                    <span class="value price">$<%= producto.precioMayorista ? producto.precioMayorista.toFixed(2) : '0.00' %></span>
                </div>
                <% if (producto.categoriaInterna) { %>
                <div class="stock-card-row">
                    <span class="label">Categoría:</span>
                    <span class="value"><%= producto.categoriaInterna %></span>
                </div>
                <% } %>
            </div>
            <div class="stock-card-footer-mobile">
                <a href="/administrador/productos/<%= producto._id %>/upstock" class="btn-mobile-action primary" aria-label="Actualizar stock de <%= producto.nombre %>">
                    📦 Actualizar Stock
                </a>
                <a href="/administrador/productos/<%= producto._id %>" class="btn-mobile-action secondary" aria-label="Ver detalle de <%= producto.nombre %>">
                    👁️ Ver Detalles
                </a>
                <a href="/administrador/productos/imprimir-codigos?ids=<%= producto._id %>" class="btn-mobile-action tertiary" target="_blank" rel="noopener" aria-label="Imprimir código del producto <%= producto.nombre %>">
                    🖨️ Código
                </a>
            </div>
        </div>
        <% }); %>
    </div>

    <!-- No Results -->
    <div id="noResults" class="empty-state" style="display: none;" aria-live="polite">
        <div class="empty-icon">🔍</div>
        <h3>No se encontraron productos</h3>
        <p>Intenta con otros términos de búsqueda</p>
        <button onclick="limpiarFiltros()" class="btn-primary-modern">Limpiar Filtros</button>
    </div>
</div>

<script>
let stockLoadedAll = false;
let stockCatalog = <%- JSON.stringify((productos || []).map((producto) => ({
    _id: String(producto._id),
    nombre: producto.nombre || '',
    marca: producto.marca || '',
    categoriaInterna: producto.categoriaInterna || '',
    cantidad: Number(producto.cantidad || 0),
    precioMinorista: Number(producto.precioMinorista || 0),
    precioMayorista: Number(producto.precioMayorista || 0),
    presentacion: producto.presentacion || '',
    peso: producto.peso || ''
}))) %>;

const stockTableBody = document.getElementById('stockTableBody');
const stockCardsMobile = document.getElementById('stockCardsMobile');
const noResults = document.getElementById('noResults');

function formatMoney(value) {
    return `$${Number(value || 0).toFixed(2)}`;
}

function renderStockDesktop(productosRender) {
    stockTableBody.innerHTML = productosRender.map((producto) => `
        <tr class="stock-row"
            data-nombre="${(producto.nombre || '').toLowerCase()}"
            data-marca="${(producto.marca || '').toLowerCase()}"
            data-categoria="${(producto.categoriaInterna || '').toLowerCase()}"
            data-stock="${Number(producto.cantidad || 0)}">
            <td>
                <div class="stock-product-cell">
                    <div class="stock-product-placeholder">📦</div>
                    <div class="stock-product-info">
                        <h4>${producto.nombre || '-'}</h4>
                        ${producto.peso ? `<p>${producto.peso}</p>` : ''}
                    </div>
                </div>
            </td>
            <td>${producto.marca || '-'}</td>
            <td style="text-align: center;">
                <span class="stock-number ${Number(producto.cantidad || 0) < 10 ? 'low' : (Number(producto.cantidad || 0) < 50 ? 'ok' : 'high')}">
                    ${Number(producto.cantidad || 0)}
                </span>
            </td>
            <td><strong style="color: #6366f1;">${formatMoney(producto.precioMinorista)}</strong></td>
            <td><strong style="color: #10b981;">${formatMoney(producto.precioMayorista)}</strong></td>
            <td>${producto.categoriaInterna || '-'}</td>
            <td>${producto.presentacion || '-'}</td>
            <td style="text-align: center;">
                <div class="stock-actions">
                    <a href="/administrador/productos/${producto._id}/upstock" class="btn-stock-action is-stock" title="Actualizar stock">
                        <span>📦</span><span>Stock</span>
                    </a>
                    <a href="/administrador/productos/${producto._id}" class="btn-stock-action is-view" title="Ver detalles">
                        <span>🔎</span><span>Ver</span>
                    </a>
                    <a href="/administrador/productos/imprimir-codigos?ids=${producto._id}" class="btn-stock-action is-print" title="Imprimir código" target="_blank" rel="noopener">
                        <span>🖨️</span><span>Código</span>
                    </a>
                </div>
            </td>
        </tr>
    `).join('');
}

function renderStockMobile(productosRender) {
    stockCardsMobile.innerHTML = productosRender.map((producto) => `
        <div class="stock-card-mobile"
             data-nombre="${(producto.nombre || '').toLowerCase()}"
             data-marca="${(producto.marca || '').toLowerCase()}"
             data-categoria="${(producto.categoriaInterna || '').toLowerCase()}"
             data-stock="${Number(producto.cantidad || 0)}">
            <div class="stock-card-header-mobile">
                <div class="stock-card-icon">📦</div>
                <div>
                    <h3 class="stock-card-title">${producto.nombre || '-'}</h3>
                    <p class="stock-card-subtitle">${producto.marca || 'Sin marca'}</p>
                </div>
            </div>
            <div class="stock-card-body-mobile">
                <div class="stock-card-row">
                    <span class="label">Stock:</span>
                    <span class="value stock-value ${Number(producto.cantidad || 0) < 10 ? 'low' : 'ok'}">${Number(producto.cantidad || 0)} unidades</span>
                </div>
                <div class="stock-card-row">
                    <span class="label">Precio Minorista:</span>
                    <span class="value price">${formatMoney(producto.precioMinorista)}</span>
                </div>
                <div class="stock-card-row">
                    <span class="label">Precio Mayorista:</span>
                    <span class="value price">${formatMoney(producto.precioMayorista)}</span>
                </div>
                ${producto.categoriaInterna ? `<div class="stock-card-row"><span class="label">Categoría:</span><span class="value">${producto.categoriaInterna}</span></div>` : ''}
            </div>
            <div class="stock-card-footer-mobile">
                <a href="/administrador/productos/${producto._id}/upstock" class="btn-mobile-action primary">📦 Actualizar stock</a>
                <a href="/administrador/productos/${producto._id}" class="btn-mobile-action secondary">🔎 Ver detalle</a>
            </div>
        </div>
    `).join('');
}

async function ensureFullStockCatalog() {
    if (stockLoadedAll) return;

    const response = await fetch('/administrador/productos/api/listado-completo');
    const payload = await response.json();
    if (payload.success && Array.isArray(payload.data)) {
        stockCatalog = payload.data;
        stockLoadedAll = true;
    }
}

async function filtrarStock() {
    const searchValue = document.getElementById('searchStock').value.toLowerCase();
    const categoriaValue = document.getElementById('filterCategoria').value.toLowerCase();
    const stockValue = document.getElementById('filterStock').value;
    const hasFilters = Boolean(searchValue || categoriaValue || stockValue);

    if (hasFilters) {
        await ensureFullStockCatalog();
    }

    const source = hasFilters ? stockCatalog : stockCatalog.slice(0, 15);
    const filtered = source.filter((producto) => {
        const nombre = (producto.nombre || '').toLowerCase();
        const marca = (producto.marca || '').toLowerCase();
        const categoria = (producto.categoriaInterna || '').toLowerCase();
        const stock = Number(producto.cantidad || 0);

        const matchSearch = nombre.includes(searchValue) || marca.includes(searchValue) || categoria.includes(searchValue);
        const matchCategoria = categoriaValue === '' || categoria === categoriaValue;

        let matchStock = true;
        if (stockValue === 'bajo') matchStock = stock < 10;
        else if (stockValue === 'medio') matchStock = stock >= 10 && stock <= 50;
        else if (stockValue === 'alto') matchStock = stock > 50;

        return matchSearch && matchCategoria && matchStock;
    });

    renderStockDesktop(filtered);
    renderStockMobile(filtered);
    noResults.style.display = filtered.length === 0 ? 'flex' : 'none';
}

function limpiarFiltros() {
    document.getElementById('searchStock').value = '';
    document.getElementById('filterCategoria').value = '';
    document.getElementById('filterStock').value = '';
    filtrarStock();
}
</script>

<%- include('../partials/footer.ejs'); %>

