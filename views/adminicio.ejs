<%- include('./partials/headerAdm.ejs'); %>

<div class="admin-dashboard">
    <!-- Hero Section -->
    <div class="dashboard-hero">
        <div class="hero-content">
            <div class="hero-text">
                <h1 class="hero-title">Panel de Stock, Caja y Ofertas</h1>
                <p class="hero-subtitle">Bienvenido <%= currentUser ? currentUser.username : '' %> · Operación centralizada de stock, ofertas, caja y cierres para SOLIDARG-COMERCIOS.</p>
            </div>
            <div class="hero-actions">
                <a href="/administrador/productos/nuevo" class="btn-primary-modern btn-save-emphasis">
                    <span class="btn-icon">📦</span>
                    Agregar productos
                </a>
                <a href="/administrador/ofertas" class="btn-secondary-modern btn-offers-entry">
                    <span class="btn-icon">🎁</span>
                    Ir a ofertas
                </a>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="quick-actions">
        <h2 class="section-title">Acciones Rápidas</h2>
        <div class="actions-grid">
            <a href="/administrador/productos" class="action-card">
                <div class="action-icon">📦</div>
                <h3>Stock</h3>
                <p>Productos, inventario y mantenimiento general del catálogo</p>
            </a>

            <a href="/administrador/productos/nuevo" class="action-card action-card-highlight">
                <div class="action-icon">🏷️</div>
                <h3>Agregar productos</h3>
                <p>Alta rápida con lector de código de barras, carga guiada y guardado directo en stock.</p>
            </a>

            <a href="/administrador/ofertas" class="action-card">
                <div class="action-icon">🎁</div>
                <h3>Ofertas</h3>
                <p>Gestiona ofertas individuales y combos para mantener promociones activas en caja.</p>
            </a>

            <a href="/administrador/buscar" class="action-card">
                <div class="action-icon">🔍</div>
                <h3>Buscar</h3>
                <p>Encuentra productos rápidamente por nombre, marca o código</p>
            </a>

            <a href="/administrador/estacionesdecobro" class="action-card">
                <div class="action-icon">💰</div>
                <h3>Caja</h3>
                <p>Controla la caja principal, ingresos y estado operativo</p>
            </a>

            <a href="/administrador/cierres-caja" class="action-card">
                <div class="action-icon">🧾</div>
                <h3>Cierres</h3>
                <p>Revisa cierres diarios, ventas registradas y control final</p>
            </a>


        </div>
    </div>

    <!-- System Info -->
    <div class="system-info">
        <div class="info-card">
            <div class="info-icon">✓</div>
            <div class="info-content">
                <p class="info-text">Panel listo para operar Stock + Ofertas + Caja + Cierres</p>
                <span class="info-time">Última actualización: Ahora</span>
            </div>
        </div>
    </div>
</div>

<%- include('./partials/footer.ejs'); %>
