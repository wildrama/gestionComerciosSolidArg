<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Caja de Cobro - <%= estacionDeCobro.ubicacionDeEstacion %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link rel="stylesheet" href="/sass/style.css">
    <link rel="stylesheet" href="/styles/caja-terminal.css">
</head>
<body>
<%- include('../partials/navbarUnificada.ejs'); %>
<%- include('../partials/flash.ejs'); %>

<div class="cash-register-shell">
    <div class="cash-mobile-warning">
        <h2>🖥️ Caja exclusiva para escritorio</h2>
        <p>Esta interfaz fue pensada para uso con lector de código de barras y operación de mostrador.</p>
    </div>

    <section class="cash-register-page">
        <header class="cash-register-header">
            <div>
                <p class="cash-kicker">Caja de cobro activa</p>
                <h1><%= estacionDeCobro.ubicacionDeEstacion %></h1>
                <p class="cash-subtitle">
                    Usuario: <strong><%= cajaData.usuarioNombre %></strong> · Rol: <strong><%= tipoUsuario %></strong> · 
                    <span><%= fechaActual %></span>
                </p>
            </div>

            <div class="cash-header-stats">
                <article class="stat-card">
                    <span>Base inicial</span>
                    <strong>$<%= Number(cajaData.dineroBase || 0).toFixed(2) %></strong>
                </article>
                <article class="stat-card">
                    <span>Disponible en caja</span>
                    <strong>$<%= Number(cajaData.dineroActual || 0).toFixed(2) %></strong>
                </article>
                <article class="stat-card">
                    <span>Fondo de cambio</span>
                    <strong>$<%= Number(cajaData.fondoCambio || 0).toFixed(2) %></strong>
                </article>
            </div>
        </header>

        <div class="cash-register-grid">
            <section class="cash-panel cash-panel-main">
                <div class="cash-toolbar">
                    <form id="barcodeForm" class="cash-search-form">
                        <label for="barcodeInput" class="form-label">Lector / búsqueda principal</label>
                        <div class="search-input-row">
                            <input id="barcodeInput" type="text" class="form-control cash-barcode-input" autocomplete="off"
                                placeholder="Escaneá el código o escribí nombre / marca" autofocus>
                            <button type="submit" class="btn btn-success cash-main-search-btn">Agregar</button>
                            <button type="button" id="focusBarcodeBtn" class="btn btn-outline-success cash-main-focus-btn">🎯 Activar lector</button>
                        </div>
                    </form>

                    <div class="cash-toolbar-actions">
                        <a href="/caja/<%= estacionDeCobro._id %>/inicio" class="btn btn-outline-secondary cash-toolbar-btn">← Resumen</a>
                        <button type="button" id="openFinderBtn" class="btn btn-outline-primary cash-toolbar-btn">🔎 Producto</button>
                        <button type="button" id="openOfferFinderBtn" class="btn btn-outline-warning cash-toolbar-btn">🎁 Oferta</button>
                        <button type="button" id="newSaleBtn" class="btn btn-outline-secondary cash-toolbar-btn">🧹 Nueva</button>
                        <button type="button" id="lastTicketBtn" class="btn btn-outline-dark cash-toolbar-btn">🖨️ Ticket</button>
                        <button type="button" id="salesHistoryBtn" class="btn btn-outline-info cash-toolbar-btn">📋 24h</button>
                    </div>
                </div>

                <div id="statusMessage" class="cash-status" hidden></div>

                <div class="cart-table-wrapper">
                    <table class="table cash-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th class="text-center">Cant.</th>
                                <th class="text-end">P. unitario</th>
                                <th class="text-end">Subtotal</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="cartTableBody">
                            <tr class="empty-state-row">
                                <td colspan="5">
                                    No hay productos cargados todavía. Escaneá con el lector o usá la búsqueda manual.
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="cash-shortcuts-note">
                    <span>💡 Atajos: <strong>F2</strong> activar lector · <strong>F4</strong> buscar producto · <strong>F6</strong> buscar oferta · <strong>F9</strong> registrar venta · <strong>Esc</strong> cerrar búsqueda</span>
                </div>
            </section>

            <aside class="cash-panel cash-panel-sidebar">
                <section class="summary-card">
                    <div class="summary-card-head">
                        <h2>Resumen de venta</h2>
                        <p>Proceso individual por cliente</p>
                    </div>

                    <div class="summary-line">
                        <span>Subtotal</span>
                        <strong id="subtotalAmount">$0.00</strong>
                    </div>
                    <div class="summary-line discount-line">
                        <span>Descuentos</span>
                        <strong id="discountAmount">$0.00</strong>
                    </div>
                    <div class="summary-line total-line">
                        <span>Total a cobrar</span>
                        <strong id="totalAmount">$0.00</strong>
                    </div>

                    <div class="payment-methods">
                        <label class="payment-option active-option">
                            <input type="radio" name="metodoPago" value="EFECTIVO" checked>
                            <span>Efectivo</span>
                        </label>
                        <label class="payment-option">
                            <input type="radio" name="metodoPago" value="DEBITO">
                            <span>Débito</span>
                        </label>
                        <label class="payment-option">
                            <input type="radio" name="metodoPago" value="CREDITO">
                            <span>Crédito</span>
                        </label>
                        <label class="payment-option">
                            <input type="radio" name="metodoPago" value="TRANSFERENCIA">
                            <span>Transferencia</span>
                        </label>
                    </div>

                    <div id="cashReceivedGroup" class="form-group mb-3">
                        <label for="cashReceivedInput" class="form-label">Efectivo recibido</label>
                        <input type="number" min="0" step="0.01" id="cashReceivedInput" class="form-control" placeholder="0.00">
                    </div>

                    <div class="summary-line change-line">
                        <span>Vuelto</span>
                        <strong id="changeAmount">$0.00</strong>
                    </div>

                    <label class="ticket-check">
                        <input type="checkbox" id="ticketToggle" checked>
                        <span>Registrar ticket entregado</span>
                    </label>

                    <button type="button" id="checkoutBtn" class="btn btn-lg btn-success w-100">
                        ✅ Registrar venta
                    </button>
                    <p class="ticket-help-note">
                        Si la impresora falla, podés usar <strong>Reimprimir último ticket</strong> incluso con una compra nueva ya iniciada.
                    </p>
                </section>

                <section class="offers-card">
                    <div class="summary-card-head">
                        <h2>🎁 Ofertas vigentes en esta caja</h2>
                        <p>Podés cargar combos o seleccionar ofertas individuales sin salir de la venta.</p>
                    </div>

                    <% if (cajaData.ofertasConjunto && cajaData.ofertasConjunto.length > 0) { %>
                        <div class="offer-block">
                            <h3 class="offer-block-title">Combos</h3>
                            <div class="offers-grid">
                                <% cajaData.ofertasConjunto.forEach((oferta, index) => { %>
                                    <button type="button" class="offer-button" data-offer-id="<%= oferta._id %>">
                                        <span class="offer-index">Combo <%= index + 1 %></span>
                                        <strong><%= oferta.nombreOferta %></strong>
                                        <small><%= oferta.productosTexto || 'Oferta combo' %></small>
                                        <span class="offer-price">$<%= Number(oferta.precioOferta || 0).toFixed(2) %></span>
                                    </button>
                                <% }) %>
                            </div>
                        </div>
                    <% } %>

                    <% if (cajaData.ofertasIndividuales && cajaData.ofertasIndividuales.length > 0) { %>
                        <div class="offer-block">
                            <h3 class="offer-block-title">Ofertas individuales</h3>
                            <div class="offers-grid">
                                <% cajaData.ofertasIndividuales.forEach((oferta) => { %>
                                    <button type="button" class="offer-button individual-offer-button" data-individual-offer-id="<%= oferta._id %>">
                                        <span class="offer-index">Oferta individual</span>
                                        <strong><%= oferta.productoEnOferta?.nombre || 'Producto' %></strong>
                                        <small><%= oferta.descripcion || `${oferta.cantidadDeUnidadesNecesarias}u por $${Number(oferta.precioOferta || 0).toFixed(2)}` %></small>
                                        <span class="offer-price">Agregar pack promocional</span>
                                    </button>
                                <% }) %>
                            </div>
                        </div>
                    <% } %>

                    <% if ((!cajaData.ofertasConjunto || !cajaData.ofertasConjunto.length) && (!cajaData.ofertasIndividuales || !cajaData.ofertasIndividuales.length)) { %>
                        <div class="empty-offer-box">
                            No hay ofertas activas asignadas a esta caja en este momento.
                        </div>
                    <% } %>

                    <div class="auto-offers-box">
                        <h3>Cómo se aplican</h3>
                        <ul>
                            <li>Las <strong>ofertas individuales</strong> se agregan desde esta misma caja y aplican el descuento automáticamente.</li>
                            <li>Los <strong>combos</strong> se suman como una línea de venta lista para cobrar.</li>
                            <li>Las promociones vencidas no se muestran en la operación diaria.</li>
                        </ul>
                    </div>
                </section>
            </aside>
        </div>
    </section>

    <div class="finder-modal" id="finderModal" hidden>
        <div class="finder-dialog">
            <div class="finder-header">
                <div>
                    <h2 id="finderTitle">Mini búsqueda de productos</h2>
                    <p id="finderSubtitle">Buscá sin perder la compra actual</p>
                </div>
                <button type="button" id="closeFinderBtn" class="btn btn-outline-secondary btn-sm">Cerrar</button>
            </div>

            <div class="finder-mode-switch" style="display:flex; gap:.5rem; margin-bottom: .75rem;">
                <button type="button" id="finderModeProducts" class="btn btn-sm btn-primary">Productos</button>
                <button type="button" id="finderModeOffers" class="btn btn-sm btn-outline-warning">Ofertas</button>
            </div>

            <form id="finderSearchForm" class="finder-form">
                <input id="finderQuery" type="text" class="form-control" placeholder="Nombre, marca o código">
                <button type="submit" class="btn btn-primary">Buscar</button>
            </form>

            <div id="finderResults" class="finder-results">
                <p class="finder-empty">Todavía no hiciste una búsqueda.</p>
            </div>
        </div>
    </div>

    <div class="finder-modal" id="salesHistoryModal" hidden>
        <div class="finder-dialog finder-dialog-wide">
            <div class="finder-header">
                <div>
                    <h2>Ventas de las últimas 24 horas</h2>
                    <p>Podés reimprimir cualquier venta del listado</p>
                </div>
                <button type="button" id="closeSalesHistoryBtn" class="btn btn-outline-secondary btn-sm">Cerrar</button>
            </div>

            <div class="sales-history-table-wrapper">
                <table class="table sales-history-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Hora</th>
                            <th>Cajero</th>
                            <th>Detalle</th>
                            <th>Total</th>
                            <th>Pago</th>
                            <th>Ticket</th>
                            <th>Acción</th>
                        </tr>
                    </thead>
                    <tbody id="salesHistoryBody">
                        <tr>
                            <td colspan="7" class="text-center text-muted">Todavía no cargaste el listado.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    window.CAJA_DATA = <%- JSON.stringify(cajaData) %>;
</script>
<script type="module" src="/js/caja-terminal.js"></script>

<%- include('../partials/footer.ejs'); %>
