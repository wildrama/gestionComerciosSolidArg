<%- include('../partials/headerAdm.ejs'); %>
<%
    const estadoOferta = ofertaConjuntoParaVer.estado || 'ACTIVA';
    const ofertaPausada = estadoOferta === 'PAUSADA';
%>

<div class="admin-dashboard">
    <div class="form-container">
        <!-- Breadcrumb -->
        <nav class="breadcrumb-nav">
            <a href="/administrador" class="breadcrumb-link">Dashboard</a>
            <span class="breadcrumb-separator">/</span>
            <a href="/administrador/ofertas" class="breadcrumb-link">Ofertas</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current"><%= ofertaConjuntoParaVer.nombreOferta %></span>
        </nav>

        <!-- Page Header -->
        <div class="form-header offer-detail-hero">
            <div>
                <h1 class="form-title">🎯 Detalles de Oferta Conjunto</h1>
                <p class="form-subtitle"><%= ofertaConjuntoParaVer.nombreOferta %></p>
            </div>
            <div class="offer-hero-right">
                <span class="offer-status-badge <%= ofertaPausada ? 'paused' : 'active' %>"><%= estadoOferta %></span>
                <div class="hero-price-card">
                    <span class="price-label">Precio especial</span>
                    <span class="price-amount">$<%= Number(ofertaConjuntoParaVer.precioOferta || 0).toFixed(2) %></span>
                </div>
            </div>
        </div>

        <!-- Details Grid -->
        <div class="oferta-details-grid">
            <!-- Información General -->
            <div class="oferta-detail-card">
                <div class="card-header">
                    <span class="card-icon">📋</span>
                    <h3 class="card-title">Información General</h3>
                </div>
                <div class="card-body-details">
                    <div class="detail-row">
                        <span class="detail-label">Nombre de la Oferta</span>
                        <span class="detail-value"><%= ofertaConjuntoParaVer.nombreOferta %></span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Precio Especial</span>
                        <span class="detail-value price">$<%= ofertaConjuntoParaVer.precioOferta.toFixed(2) %></span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Vigente Hasta</span>
                        <span class="detail-value">
                            <%= ofertaConjuntoParaVer.fechaDeVigencia ? new Date(ofertaConjuntoParaVer.fechaDeVigencia).toLocaleDateString('es-AR', { year: 'numeric', month: 'long', day: 'numeric' }) : 'Sin fecha límite' %>
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Código de oferta</span>
                        <span class="detail-value"><span class="code-chip"><%= ofertaConjuntoParaVer.codigoOferta || 'Sin código' %></span></span>
                    </div>
                </div>
            </div>

            <!-- Estaciones -->
            <div class="oferta-detail-card">
                <div class="card-header">
                    <span class="card-icon">🏪</span>
                    <h3 class="card-title">Estaciones de Cobro</h3>
                </div>
                <div class="card-body-details">
                    <div class="stations-list-inline">
                        <% if (ofertaConjuntoParaVer.estacionesDeCobroParaLaOferta && ofertaConjuntoParaVer.estacionesDeCobroParaLaOferta.length > 0) { %>
                            <% ofertaConjuntoParaVer.estacionesDeCobroParaLaOferta.forEach(estacion => { %>
                                <span class="station-badge">🏪 <%= estacion.ubicacionDeEstacion %></span>
                            <% }); %>
                        <% } else { %>
                            <p class="no-data">No hay estaciones asignadas</p>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Productos Incluidos -->
            <div class="oferta-detail-card full-width">
                <div class="card-header">
                    <span class="card-icon">📦</span>
                    <h3 class="card-title">Productos Incluidos en la Oferta</h3>
                </div>
                <div class="card-body-details">
                    <% if (ofertaConjuntoParaVer.productosEnOfertaConCodigo && ofertaConjuntoParaVer.productosEnOfertaConCodigo.length > 0) { %>
                        <div class="products-table-wrapper">
                            <table class="products-table">
                                <thead>
                                    <tr>
                                        <th>Producto</th>
                                        <th style="text-align: center;">Marca</th>
                                        <th style="text-align: center;">Precio Original</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% ofertaConjuntoParaVer.productosEnOfertaConCodigo.forEach(producto => { %>
                                    <tr>
                                        <td>
                                            <div class="product-cell">
                                                <span class="product-icon">📦</span>
                                                <span><%= producto.nombre %></span>
                                            </div>
                                        </td>
                                        <td style="text-align: center;"><%= producto.marca || '-' %></td>
                                        <td style="text-align: center;">
                                            <span class="price-badge">$<%= producto.precioMinorista ? producto.precioMinorista.toFixed(2) : '-' %></span>
                                        </td>
                                    </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <p class="no-data">No hay productos asociados a esta oferta</p>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Summary -->
        <div class="oferta-summary-card">
            <h3 class="summary-title">📊 Resumen</h3>
            <div class="summary-grid">
                <div class="summary-item">
                    <span class="summary-label">Productos Incluidos</span>
                    <span class="summary-value">
                        <%= ofertaConjuntoParaVer.productosEnOfertaConCodigo ? ofertaConjuntoParaVer.productosEnOfertaConCodigo.length : 0 %>
                    </span>
                </div>
                <div class="summary-item">
                    <span class="summary-label">Estaciones</span>
                    <span class="summary-value">
                        <%= ofertaConjuntoParaVer.estacionesDeCobroParaLaOferta ? ofertaConjuntoParaVer.estacionesDeCobroParaLaOferta.length : 0 %>
                    </span>
                </div>
                <div class="summary-item">
                    <span class="summary-label">Estado</span>
                    <span class="summary-value <%= ofertaPausada ? 'status-paused' : 'status-active' %>"><%= estadoOferta %></span>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="reset-info-box mt-3">
            <span class="info-icon">ℹ️</span>
            <p class="info-text">Las ofertas combo no se editan: si hay que cambiar precio, productos o vigencia, <strong>pausala o eliminála y creá una nueva</strong>.</p>
        </div>

        <div class="form-actions">
            <a href="/administrador/ofertas" class="btn-secondary-modern">
                ← Volver a Ofertas
            </a>
            <a href="/administrador/ofertas/imprimir-codigos?ids=<%= ofertaConjuntoParaVer._id %>" class="btn-primary-modern btn-save-emphasis" target="_blank" rel="noopener">
                🖨️ Imprimir código del combo
            </a>
            <form action="/administrador/ofertas/oferta-conjunto/<%= ofertaConjuntoParaVer._id %>/estado" method="POST" style="display:inline;">
                <input type="hidden" name="estado" value="<%= ofertaPausada ? 'ACTIVA' : 'PAUSADA' %>">
                <button type="submit" class="<%= ofertaPausada ? 'btn-primary-modern btn-save-emphasis' : 'btn-secondary-modern btn-offers-entry' %>">
                    <%= ofertaPausada ? '▶️ Reactivar oferta' : '⏸️ Pausar oferta' %>
                </button>
            </form>
            <form action="/administrador/ofertas/oferta-conjunto/<%= ofertaConjuntoParaVer._id %>?_method=DELETE" 
                  method="POST" 
                  style="display: inline;"
                  onsubmit="return confirm('¿Estás seguro de eliminar esta oferta?')">
                <button type="submit" class="btn-delete-full">
                    🗑️ Eliminar Oferta
                </button>
            </form>
        </div>

        <style>
            .offer-detail-hero {
                display: flex;
                justify-content: space-between;
                align-items: center;
                gap: 1rem;
                flex-wrap: wrap;
            }
            .offer-hero-right {
                display: flex;
                align-items: center;
                gap: 0.85rem;
                flex-wrap: wrap;
            }
            .offer-status-badge {
                padding: 0.45rem 0.8rem;
                border-radius: 999px;
                font-weight: 700;
            }
            .offer-status-badge.active { background:#dcfce7; color:#166534; }
            .offer-status-badge.paused { background:#fee2e2; color:#991b1b; }
            .hero-price-card {
                display: flex;
                flex-direction: column;
                align-items: flex-end;
                gap: 0.2rem;
                padding: 0.75rem 0.95rem;
                border-radius: 14px;
                background: #ffffff;
                border: 1px solid rgba(99, 102, 241, 0.16);
                box-shadow: 0 10px 22px rgba(15, 23, 42, 0.06);
            }
            .price-label {
                font-size: 0.78rem;
                text-transform: uppercase;
                letter-spacing: 0.04em;
                color: #64748b;
                font-weight: 700;
            }
            .price-amount {
                font-size: 1.6rem;
                font-weight: 800;
                color: #0f172a;
                line-height: 1;
            }
            .oferta-details-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
                gap: 1rem;
                margin-top: 1rem;
            }
            .oferta-detail-card,
            .oferta-summary-card {
                background: #ffffff;
                border: 1px solid rgba(99, 102, 241, 0.12);
                border-radius: 16px;
                box-shadow: 0 12px 24px rgba(15, 23, 42, 0.06);
            }
            .oferta-detail-card.full-width { grid-column: 1 / -1; }
            .card-header {
                display: flex;
                align-items: center;
                gap: 0.65rem;
                padding: 1rem 1.1rem;
                border-bottom: 1px solid #e5e7eb;
            }
            .card-icon { font-size: 1.15rem; }
            .card-title {
                margin: 0;
                font-size: 1.02rem;
                color: #0f172a;
            }
            .card-body-details { padding: 1rem 1.1rem; }
            .detail-row {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 1rem;
                padding: 0.7rem 0;
                border-bottom: 1px dashed #e5e7eb;
            }
            .detail-row:last-child { border-bottom: none; }
            .detail-label {
                color: #64748b;
                font-weight: 600;
                font-size: 0.92rem;
            }
            .detail-value {
                color: #0f172a;
                font-weight: 600;
                text-align: right;
            }
            .detail-value.price { color: #166534; }
            .code-chip {
                display: inline-flex;
                align-items: center;
                font-family:'Courier New', monospace;
                background:#eef2ff;
                color:#3730a3;
                padding:0.3rem 0.6rem;
                border-radius:999px;
            }
            .stations-list-inline {
                display: flex;
                gap: 0.55rem;
                flex-wrap: wrap;
            }
            .station-badge {
                display: inline-flex;
                align-items: center;
                gap: 0.35rem;
                padding: 0.45rem 0.7rem;
                border-radius: 999px;
                background: #f8fafc;
                border: 1px solid #dbeafe;
                color: #1d4ed8;
                font-weight: 600;
            }
            .products-table-wrapper { overflow-x: auto; }
            .products-table {
                width: 100%;
                border-collapse: collapse;
            }
            .products-table th {
                background: #f8fafc;
                color: #475569;
                font-size: 0.84rem;
                text-transform: uppercase;
                letter-spacing: 0.03em;
                padding: 0.75rem;
            }
            .products-table td {
                padding: 0.85rem 0.75rem;
                border-top: 1px solid #e5e7eb;
            }
            .product-cell {
                display: flex;
                align-items: center;
                gap: 0.6rem;
                font-weight: 600;
                color: #0f172a;
            }
            .price-badge {
                display: inline-flex;
                padding: 0.35rem 0.6rem;
                border-radius: 999px;
                background: #dcfce7;
                color: #166534;
                font-weight: 700;
            }
            .oferta-summary-card {
                margin-top: 1rem;
                padding: 1rem 1.1rem;
            }
            .summary-title {
                margin: 0 0 0.85rem 0;
                font-size: 1.02rem;
                color: #0f172a;
            }
            .summary-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
                gap: 0.8rem;
            }
            .summary-item {
                display: flex;
                flex-direction: column;
                gap: 0.35rem;
                padding: 0.85rem 0.9rem;
                border-radius: 14px;
                background: #f8fafc;
                border: 1px solid #e5e7eb;
            }
            .summary-label {
                font-size: 0.84rem;
                color: #64748b;
                font-weight: 600;
            }
            .summary-value {
                font-size: 1.2rem;
                font-weight: 800;
                color: #0f172a;
            }
            .status-active { color:#166534; }
            .status-paused { color:#991b1b; }
            .no-data {
                margin: 0;
                color: #64748b;
            }
            @media (max-width: 768px) {
                .detail-row {
                    flex-direction: column;
                    align-items: flex-start;
                }
                .detail-value {
                    text-align: left;
                }
                .hero-price-card {
                    align-items: flex-start;
                }
            }
        </style>
    </div>
</div>

<%- include('../partials/footer.ejs'); %>
