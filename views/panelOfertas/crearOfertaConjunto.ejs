<%- include('../partials/headerAdm.ejs'); %>

<div class="admin-dashboard">
    <div class="form-container">
        <!-- Breadcrumb -->
        <nav class="breadcrumb-nav">
            <a href="/administrador" class="breadcrumb-link">Dashboard</a>
            <span class="breadcrumb-separator">/</span>
            <a href="/administrador/ofertas" class="breadcrumb-link">Ofertas</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current">Crear Oferta Conjunto</span>
        </nav>

        <!-- Page Header -->
        <div class="form-header">
            <h1 class="form-title">🎯 Nueva Oferta Conjunto</h1>
            <p class="form-subtitle">Armala en orden: datos básicos, cajas donde aplica, productos incluidos y guardado final.</p>
        </div>

        <div class="setup-next-steps offer-step-guide">
            <h3 class="steps-title">Orden recomendado</h3>
            <ul class="steps-list">
                <li><span class="step-number">1</span><span class="step-text">Completá nombre, precio promocional y vigencia.</span></li>
                <li><span class="step-number">2</span><span class="step-text">Elegí una o varias cajas donde va a estar disponible.</span></li>
                <li><span class="step-number">3</span><span class="step-text">Buscá y agregá los productos del combo.</span></li>
            </ul>
        </div>

        <!-- Info Alert -->
        <div class="info-alert">
            <span class="alert-icon">💡</span>
            <p class="alert-text">Las ofertas de conjunto aplican un descuento especial cuando se compran múltiples productos juntos</p>
        </div>

        <!-- Main Form -->
        <form action="/administrador/ofertas/agregar-oferta-conjunto" method="POST" class="modern-form">
            <div class="form-grid">
                <!-- Información Básica -->
                <div class="form-section">
                    <h3 class="section-title-form">📝 Información de la Oferta</h3>
                    
                    <div class="form-group-modern">
                        <label for="nombreOferta" class="form-label-modern">Nombre de la Oferta *</label>
                        <div class="input-with-icon">
                            <span class="input-icon">🎁</span>
                            <input type="text" 
                                   id="nombreOferta" 
                                   name="nombreOferta" 
                                   class="form-control-modern with-icon" 
                                   placeholder="Ej: Combo Burger + Bebida"
                                   required>
                        </div>
                        <small class="form-help">Nombre descriptivo de la oferta</small>
                    </div>

                    <div class="form-row">
                        <div class="form-group-modern">
                            <label for="precioOferta" class="form-label-modern">Precio de la Oferta *</label>
                            <div class="input-with-icon">
                                <span class="input-icon">$</span>
                                <input type="number" 
                                       id="precioOferta" 
                                       name="precioOferta" 
                                       class="form-control-modern with-icon" 
                                       placeholder="0.00"
                                       step="0.01"
                                       min="0"
                                       required>
                            </div>
                            <small class="form-help">Precio especial del conjunto</small>
                        </div>

                        <div class="form-group-modern">
                            <label for="fechaDeVigencia" class="form-label-modern">Fecha de Vigencia *</label>
                            <div class="input-with-icon">
                                <span class="input-icon">📅</span>
                                <input type="date" 
                                       id="fechaDeVigencia" 
                                       name="fechaDeVigencia" 
                                       class="form-control-modern with-icon"
                                       required>
                            </div>
                            <small class="form-help">Hasta cuándo estará vigente</small>
                        </div>
                    </div>
                </div>

                <!-- Estaciones -->
                <div class="form-section">
                    <h3 class="section-title-form">🏪 Aplicar en Estaciones</h3>
                    
                    <div class="form-group-modern">
                        <label class="form-label-modern">Seleccioná una o varias cajas *</label>
                        <div class="station-select-actions">
                            <button type="button" id="selectAllStationsBtn" class="btn-light-modern">Seleccionar todas</button>
                            <button type="button" id="clearStationsBtn" class="btn-light-modern">Limpiar</button>
                        </div>
                        <div class="stations-check-grid" id="estacionDeCobroParaLaOferta">
                            <% if (estacionesDeCobro && estacionesDeCobro.length > 0) { %>
                                <% estacionesDeCobro.forEach(estacion => { %>
                                <label class="station-check-card">
                                    <input type="checkbox"
                                           name="estacionDeCobroParaLaOferta"
                                           value="<%= estacion._id %>"
                                           class="station-checkbox"
                                           <%= estacion.ubicacionDeEstacion === 'CAJA 1' ? 'checked' : '' %>>
                                    <span class="station-check-icon">🏪</span>
                                    <span class="station-check-copy">
                                        <strong><%= estacion.ubicacionDeEstacion %></strong>
                                        <small>La oferta quedará disponible en esta caja.</small>
                                    </span>
                                </label>
                                <% }); %>
                            <% } else { %>
                                <p class="no-selection">No hay estaciones disponibles.</p>
                            <% } %>
                        </div>
                        <small class="form-help">Podés activar la misma oferta en varias cajas al mismo tiempo.</small>
                    </div>

                    <div class="estaciones-preview">
                        <p class="preview-label">Cajas seleccionadas:</p>
                        <div id="selectedStations" class="selected-stations-list"></div>
                    </div>
                </div>

                <!-- Productos Incluidos -->
                <div class="form-section full-width">
                    <h3 class="section-title-form">📦 Productos vinculados al stock del combo</h3>
                    
                    <p class="section-description">Este paso es <strong>opcional</strong>. Si vinculás productos de stock, al vender el combo se descontarán automáticamente. Si no agregás ninguno, la oferta se cobra igual sin tocar stock.</p>
                    
                    <div id="formSearchOfertaConjunto" class="products-search-area" role="search">
                        <div class="search-box-conjunto">
                            <span class="search-icon-conjunto">🔍</span>
                            <input type="text" 
                                   id="searchProductCode" 
                                   class="search-input-conjunto" 
                                   placeholder="Ej: arroz, coca cola o 779..."
                                   autocomplete="off">
                        </div>
                        <button type="button" id="btnBuscarProductoConjunto" class="btn-add-product">
                            <span class="btn-icon">🔎</span>
                            Buscar y agregar
                        </button>
                    </div>

                    <div id="comboSearchResults" class="finder-results" style="margin-bottom: 1rem;"></div>
                    <small class="form-help">Si elegís productos acá, cuando ese combo se venda en caja se descontará su stock automáticamente.</small>

                    <div class="products-list-container">
                        <div id="productosEnConjunto" class="productos-conjunto-list">
                            <div class="empty-products">
                                <span class="empty-icon">📦</span>
                                <p>Opcional: todavía no vinculaste productos de stock al combo</p>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" id="productosIds" name="productosEnOfertaConCodigo" value="">
                </div>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
                <a href="/administrador/ofertas" class="btn-secondary-modern">
                    ← Cancelar
                </a>
                <button type="submit" class="btn-primary-modern btn-save-emphasis">
                    <span class="btn-icon">✓</span>
                    Crear oferta conjunto
                </button>
            </div>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/ofertasFunc.js"></script>

<script>
const stationCheckboxes = Array.from(document.querySelectorAll('.station-checkbox'));
const selectedStationsList = document.getElementById('selectedStations');
const selectAllStationsBtn = document.getElementById('selectAllStationsBtn');
const clearStationsBtn = document.getElementById('clearStationsBtn');
const comboForm = document.querySelector('.modern-form');
const productosIds = document.getElementById('productosIds');

function updateSelectedStations() {
    const selected = stationCheckboxes
        .filter((checkbox) => checkbox.checked)
        .map((checkbox) => checkbox.closest('.station-check-card')?.querySelector('strong')?.textContent?.trim())
        .filter(Boolean);

    stationCheckboxes.forEach((checkbox) => {
        checkbox.closest('.station-check-card')?.classList.toggle('selected', checkbox.checked);
    });

    if (selected.length === 0) {
        selectedStationsList.innerHTML = '<p class="no-selection">Seleccioná al menos una caja para publicar esta oferta.</p>';
        return;
    }

    selectedStationsList.innerHTML = selected
        .map((station) => `<span class="station-badge">${station}</span>`)
        .join('');
}

stationCheckboxes.forEach((checkbox) => checkbox.addEventListener('change', updateSelectedStations));
selectAllStationsBtn?.addEventListener('click', () => {
    stationCheckboxes.forEach((checkbox) => { checkbox.checked = true; });
    updateSelectedStations();
});
clearStationsBtn?.addEventListener('click', () => {
    stationCheckboxes.forEach((checkbox) => { checkbox.checked = false; });
    updateSelectedStations();
});

comboForm?.addEventListener('submit', (event) => {
    if (!stationCheckboxes.some((checkbox) => checkbox.checked)) {
        event.preventDefault();
        window.alert('Seleccioná al menos una caja para aplicar la oferta.');
    }
});

updateSelectedStations();
</script>

<%- include('../partials/footer.ejs'); %>
