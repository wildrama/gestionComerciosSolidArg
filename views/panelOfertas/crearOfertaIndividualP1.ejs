<%- include('../partials/headerAdm.ejs'); %>

<div class="admin-dashboard">
    <div class="form-container">
        <!-- Breadcrumb -->
        <nav class="breadcrumb-nav">
            <a href="/administrador" class="breadcrumb-link">Dashboard</a>
            <span class="breadcrumb-separator">/</span>
            <a href="/administrador/ofertas" class="breadcrumb-link">Ofertas</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current">Crear Oferta Individual</span>
        </nav>

        <!-- Page Header -->
        <div class="form-header">
            <h1 class="form-title">🎁 Nueva Oferta Individual</h1>
            <p class="form-subtitle">Creala en orden: buscá el producto, revisalo y seguí al paso de configuración.</p>
        </div>

        <div class="setup-next-steps offer-step-guide">
            <h3 class="steps-title">Orden recomendado</h3>
            <ul class="steps-list">
                <li><span class="step-number">1</span><span class="step-text"><strong>Buscá</strong> el producto por nombre, marca o código de barras.</span></li>
                <li><span class="step-number">2</span><span class="step-text"><strong>Seleccioná</strong> el producto correcto del listado.</span></li>
                <li><span class="step-number">3</span><span class="step-text"><strong>Configurá</strong> precio, vigencia y cajas en el siguiente paso.</span></li>
            </ul>
        </div>

        <!-- Search Section -->
        <div class="offer-search-card">
            <h3 class="offer-search-title">Paso 1 · Buscar producto</h3>
            <p class="section-description">Podés escribir texto o escanear directamente el código de barras.</p>
            
            <form id="searchBarFormCodigoIndividual" class="offer-search-form">
                <div class="search-box-offer">
                    <span class="search-icon-offer">📦</span>
                    <input type="text" 
                           name="codigoDeProducto" 
                           id="codigoIndividualInput" 
                           class="search-input-offer" 
                           placeholder="Ej: coca cola, pepsi o 779..."
                           autocomplete="off">
                </div>
                
                <button type="submit" class="btn-search-offer">
                    <span class="btn-icon">🔍</span>
                    Buscar productos
                </button>
            </form>
            <small class="form-help">La búsqueda funciona igual que la del stock: por texto o por código de barra. Después elegí el producto desde las tarjetas de abajo.</small>
        </div>

        <div id="offerSearchResults" class="finder-results" style="margin-bottom: 1rem;"></div>

        <!-- Product Result -->
        <div class="offer-result-section">
            <h3 class="offer-result-title">Paso 2 · Revisar producto seleccionado</h3>
            <p class="section-description">Verificá que sea el producto correcto antes de pasar a la configuración de la oferta.</p>
            
            <div id="productoIndividualContainer" class="product-result-card">
                <div class="result-empty-state">
                    <div class="empty-icon">📦</div>
                    <p>Busca un producto para ver sus detalles aquí</p>
                </div>

                <!-- Este contenedor se actualiza dinámicamente -->
                <div id="productResultContent" style="display: none;">
                    <div class="result-grid">
                        <div class="result-item">
                            <span class="result-label">Nombre del Producto</span>
                            <p id="nombreProdIndividual" class="result-value"></p>
                        </div>
                        
                        <div class="result-item">
                            <span class="result-label">Marca</span>
                            <p id="marcaProdIndividual" class="result-value"></p>
                        </div>
                        
                        <div class="result-item">
                            <span class="result-label">Precio Actual</span>
                            <p id="precioProdIndividual" class="result-value price"></p>
                        </div>
                        
                        <div class="result-item">
                            <span class="result-label">Stock Disponible</span>
                            <p id="cantidadProdIndividual" class="result-value"></p>
                        </div>

                        <div class="result-item">
                            <span class="result-label">Código de Barra</span>
                            <p id="idContainer" class="result-value"></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="form-actions">
            <a href="/administrador/ofertas" class="btn-secondary-modern">
                ← Volver a ofertas
            </a>
            <a id="btn2daPantalla" href="#" class="btn-primary-modern btn-save-emphasis is-disabled" aria-disabled="true">
                <span class="btn-icon">→</span>
                Seguir a configurar la oferta
            </a>
        </div>
    </div>
</div>

<script src="/ofertasFunc.js"></script>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

<script>
const container = document.getElementById('productoIndividualContainer');
const resultContent = document.getElementById('productResultContent');
const emptyState = container.querySelector('.result-empty-state');

function updateSelectedProductState() {
    const hasContent = document.getElementById('nombreProdIndividual')?.textContent?.trim();

    if (hasContent) {
        emptyState.style.display = 'none';
        resultContent.style.display = 'block';
        btn2daPantalla?.setAttribute('aria-disabled', 'false');
        btn2daPantalla?.classList.remove('is-disabled');
    } else {
        emptyState.style.display = 'flex';
        resultContent.style.display = 'none';
        btn2daPantalla?.setAttribute('href', '#');
        btn2daPantalla?.setAttribute('aria-disabled', 'true');
        btn2daPantalla?.classList.add('is-disabled');
    }
}

const observer = new MutationObserver(updateSelectedProductState);
observer.observe(container, { childList: true, subtree: true, characterData: true });
updateSelectedProductState();

btn2daPantalla?.addEventListener('click', function(event) {
    if (btn2daPantalla.getAttribute('aria-disabled') === 'true') {
        event.preventDefault();
    }
});
</script>

<%- include('../partials/footer.ejs'); %>
