<%- include('../partials/headerAdm.ejs'); %>

<div class="admin-dashboard">
    <div class="form-container">
        <!-- Breadcrumb -->
        <nav class="breadcrumb-nav">
            <a href="/administrador" class="breadcrumb-link">Dashboard</a>
            <span class="breadcrumb-separator">/</span>
            <a href="/administrador/ofertas" class="breadcrumb-link">Ofertas</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current">Crear Oferta Individual - Paso 2</span>
        </nav>

        <!-- Page Header -->
        <div class="form-header">
            <h1 class="form-title">🎁 Configurar Oferta Individual</h1>
            <p class="form-subtitle">Definí la promo en orden: cantidad, precio, vigencia y en qué cajas se mostrará.</p>
        </div>

        <div class="setup-next-steps offer-step-guide">
            <h3 class="steps-title">Pasos de esta pantalla</h3>
            <ul class="steps-list">
                <li><span class="step-number">1</span><span class="step-text">Indicá cuántas unidades activan la promo.</span></li>
                <li><span class="step-number">2</span><span class="step-text">Definí el precio promocional y la fecha de vigencia.</span></li>
                <li><span class="step-number">3</span><span class="step-text">Marcá una o varias cajas donde querés habilitarla.</span></li>
            </ul>
        </div>

        <!-- Product Info Card -->
        <div class="offer-product-info">
            <div class="info-header">
                <span class="info-icon">📦</span>
                <div>
                    <h3 class="info-product-name"><%= productoParaOfertaIndividual.nombre %></h3>
                    <p class="info-product-meta"><%= productoParaOfertaIndividual.marca %> · Cod. <%= productoParaOfertaIndividual.codigo || 'sin código' %></p>
                </div>
            </div>
            <div class="info-price">
                <span class="price-label">Precio Actual:</span>
                <span class="price-value">$<%= productoParaOfertaIndividual.precioMinorista.toFixed(2) %></span>
            </div>
        </div>

        <!-- Offer Form -->
        <form action="/administrador/ofertas/agregar-oferta-individual/nueva" method="POST" class="modern-form">
            <div class="form-grid">
                <!-- Detalles de la Oferta -->
                <div class="form-section">
                    <h3 class="section-title-form">💰 Detalles de la Oferta</h3>
                    
                    <div class="form-group-modern">
                        <label for="cantidadDeUnidadesNecesarias" class="form-label-modern">
                            Cantidad de Unidades Necesarias *
                        </label>
                        <div class="input-with-icon">
                            <span class="input-icon">📊</span>
                            <input type="number" 
                                   id="cantidadDeUnidadesNecesarias" 
                                   name="cantidadDeUnidadesNecesarias" 
                                   class="form-control-modern with-icon" 
                                   placeholder="Ej: 3"
                                   min="1"
                                   required>
                        </div>
                        <small class="form-help">Cantidad mínima de unidades para aplicar la oferta</small>
                    </div>

                    <div class="form-group-modern">
                        <label for="precioOferta" class="form-label-modern">Precio de la Oferta *</label>
                        <div class="input-with-icon">
                            <span class="input-icon">$</span>
                            <input type="number" 
                                   id="precioOferta" 
                                   name="precioOferta" 
                                   class="form-control-modern with-icon" 
                                   placeholder="0.00"
                                   step="0.01"
                                   min="0"
                                   required>
                        </div>
                        <small class="form-help">Precio especial de la oferta</small>
                    </div>

                    <div class="form-group-modern">
                        <label for="fechaDeVigencia" class="form-label-modern">Fecha de Vigencia *</label>
                        <div class="input-with-icon">
                            <span class="input-icon">📅</span>
                            <input type="date" 
                                   id="fechaDeVigencia" 
                                   name="fechaDeVigencia" 
                                   class="form-control-modern with-icon"
                                   required>
                        </div>
                        <small class="form-help">Hasta cuándo estará vigente esta oferta</small>
                    </div>
                </div>

                <!-- Estaciones de Cobro -->
                <div class="form-section">
                    <h3 class="section-title-form">🏪 Aplicar en Estaciones</h3>
                    
                    <div class="form-group-modern">
                        <label class="form-label-modern">Seleccioná una o varias cajas *</label>
                        <div class="station-select-actions">
                            <button type="button" id="selectAllStationsBtn" class="btn-light-modern">Seleccionar todas</button>
                            <button type="button" id="clearStationsBtn" class="btn-light-modern">Limpiar</button>
                        </div>
                        <div class="stations-check-grid" id="estacionDeCobroParaLaOferta">
                            <% for(let estacionDeCobro of estacionesDeCobro) { %>
                                <label class="station-check-card">
                                    <input type="checkbox"
                                           name="estacionDeCobroParaLaOferta"
                                           value="<%= estacionDeCobro._id %>"
                                           class="station-checkbox"
                                           <%= estacionDeCobro.ubicacionDeEstacion === 'CAJA 1' ? 'checked' : '' %>>
                                    <span class="station-check-icon">🏪</span>
                                    <span class="station-check-copy">
                                        <strong><%= estacionDeCobro.ubicacionDeEstacion %></strong>
                                        <small>La oferta también se mostrará en esta caja.</small>
                                    </span>
                                </label>
                            <% } %>
                        </div>
                        <small class="form-help">Podés marcar varias cajas sin usar Ctrl ni combinaciones raras.</small>
                    </div>

                    <div class="estaciones-preview">
                        <p class="preview-label">Cajas seleccionadas:</p>
                        <div id="selectedStations" class="selected-stations-list"></div>
                    </div>
                </div>
            </div>

            <!-- Hidden Input -->
            <input type="hidden" 
                   name="productoEnOferta" 
                   value="<%= productoParaOfertaIndividual._id %>">

            <!-- Form Actions -->
            <div class="form-actions">
                <a href="/administrador/ofertas/agregar-oferta-individual" class="btn-secondary-modern">
                    ← Volver al Paso 1
                </a>
                <button type="submit" class="btn-primary-modern btn-save-emphasis">
                    <span class="btn-icon">✓</span>
                    Crear oferta individual
                </button>
            </div>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script>
const stationCheckboxes = Array.from(document.querySelectorAll('.station-checkbox'));
const selectedStationsList = document.getElementById('selectedStations');
const selectAllStationsBtn = document.getElementById('selectAllStationsBtn');
const clearStationsBtn = document.getElementById('clearStationsBtn');
const offerForm = document.querySelector('.modern-form');

function updateSelectedStations() {
    const selected = stationCheckboxes
        .filter((checkbox) => checkbox.checked)
        .map((checkbox) => checkbox.closest('.station-check-card')?.querySelector('strong')?.textContent?.trim())
        .filter(Boolean);

    stationCheckboxes.forEach((checkbox) => {
        checkbox.closest('.station-check-card')?.classList.toggle('selected', checkbox.checked);
    });

    if (selected.length === 0) {
        selectedStationsList.innerHTML = '<p class="no-selection">Seleccioná al menos una caja para continuar.</p>';
        return;
    }

    selectedStationsList.innerHTML = selected
        .map((station) => `<span class="station-badge">${station}</span>`)
        .join('');
}

stationCheckboxes.forEach((checkbox) => checkbox.addEventListener('change', updateSelectedStations));
selectAllStationsBtn?.addEventListener('click', () => {
    stationCheckboxes.forEach((checkbox) => { checkbox.checked = true; });
    updateSelectedStations();
});
clearStationsBtn?.addEventListener('click', () => {
    stationCheckboxes.forEach((checkbox) => { checkbox.checked = false; });
    updateSelectedStations();
});

offerForm?.addEventListener('submit', (event) => {
    if (!stationCheckboxes.some((checkbox) => checkbox.checked)) {
        event.preventDefault();
        window.alert('Seleccioná al menos una caja para aplicar la oferta.');
    }
});

updateSelectedStations();
</script>

<%- include('../partials/footer.ejs'); %>
