<%- include('../partials/headerAdm.ejs'); %>

<div class="admin-dashboard" id="admin-main-content">
    <div class="form-container">
        <!-- Breadcrumb -->
        <nav class="breadcrumb-nav">
            <a href="/administrador" class="breadcrumb-link">Dashboard</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current">Ofertas</span>
        </nav>

        <!-- Page Header -->
        <div class="form-header">
            <h1 class="form-title">🎁 Gestión de Ofertas</h1>
            <p class="form-subtitle">Crea y administra ofertas de productos individuales y conjuntos</p>
        </div>

        <!-- Quick Actions -->
        <div class="ofertas-actions">
            <a href="/administrador/ofertas/agregar-oferta-individual" class="btn-oferta-action btn-individual">
                <span class="btn-icon">📦</span>
                <span>Agregar Oferta Individual</span>
            </a>
            <a href="/administrador/ofertas/agregar-oferta-conjunto" class="btn-oferta-action btn-conjunto">
                <span class="btn-icon">🎯</span>
                <span>Agregar Oferta Conjunto</span>
            </a>
            <a href="/administrador/ofertas/imprimir-codigos" class="btn-oferta-action btn-individual" target="_blank" rel="noopener">
                <span class="btn-icon">🖨️</span>
                <span>Imprimir códigos de combos</span>
            </a>
        </div>

        <!-- Ofertas Individuales -->
        <div class="ofertas-section">
            <h2 class="ofertas-section-title">📦 Ofertas Individuales</h2>
            
            <% if (ofertasIndividuales && ofertasIndividuales.length > 0) { %>
            <div class="ofertas-table-wrapper">
                <table class="ofertas-table" aria-label="Listado de ofertas individuales">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th style="text-align: center;">Precio Oferta</th>
                            <th style="text-align: center;">Cantidad Necesaria</th>
                            <th style="text-align: center;">Vigencia</th>
                            <th style="text-align: center;">Estado</th>
                            <th style="text-align: center;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% ofertasIndividuales.forEach(oferta => { %>
                        <tr class="oferta-row">
                            <td data-label="Producto:">
                                <div class="oferta-product-cell">
                                    <span class="product-icon">📦</span>
                                    <div>
                                        <a href="/administrador/ofertas/oferta-individual/<%= oferta._id %>" class="product-link">
                                            <%= oferta.productoEnOferta.nombre %>
                                        </a>
                                        <div><small>Cód. oferta: <%= oferta.codigoOferta || '-' %></small></div>
                                    </div>
                                </div>
                            </td>
                            <td data-label="Precio:" style="text-align: center;">
                                <span class="price-badge">$<%= oferta.precioOferta.toFixed(2) %></span>
                            </td>
                            <td data-label="Cantidad:" style="text-align: center;">
                                <span class="quantity-badge"><%= oferta.cantidadDeUnidadesNecesarias %> unid.</span>
                            </td>
                            <td data-label="Vigencia:" style="text-align: center;">
                                <span class="date-badge">
                                    <%= oferta.fechaDeVigencia ? new Date(oferta.fechaDeVigencia).toLocaleDateString('es-AR') : '-' %>
                                </span>
                            </td>
                            <td data-label="Estado:" style="text-align: center;">
                                <span class="status-pill <%= (oferta.estado || 'ACTIVA') === 'PAUSADA' ? 'is-paused' : 'is-active' %>">
                                    <%= oferta.estado || 'ACTIVA' %>
                                </span>
                            </td>
                            <td data-label="Acciones:" style="text-align: center;">
                                <div class="oferta-actions">
                                    <a href="/administrador/ofertas/oferta-individual/<%= oferta._id %>" class="btn-oferta-view" title="Ver detalles" aria-label="Ver detalle de la oferta <%= oferta.productoEnOferta.nombre %>">
                                        👁️
                                    </a>
                                    <form action="/administrador/ofertas/oferta-individual/<%= oferta._id %>/estado" 
                                          method="POST" 
                                          class="inline-action-form">
                                        <input type="hidden" name="estado" value="<%= (oferta.estado || 'ACTIVA') === 'PAUSADA' ? 'ACTIVA' : 'PAUSADA' %>">
                                        <button type="submit" class="btn-oferta-view" title="<%= (oferta.estado || 'ACTIVA') === 'PAUSADA' ? 'Reactivar' : 'Pausar' %>" aria-label="<%= (oferta.estado || 'ACTIVA') === 'PAUSADA' ? 'Reactivar' : 'Pausar' %> oferta <%= oferta.productoEnOferta.nombre %>">
                                            <%= (oferta.estado || 'ACTIVA') === 'PAUSADA' ? '▶️' : '⏸️' %>
                                        </button>
                                    </form>
                                    <form action="/administrador/ofertas/oferta-individual/<%= oferta._id %>?_method=DELETE" 
                                          method="POST" 
                                          class="inline-action-form"
                                          onsubmit="return confirm('¿Eliminar esta oferta?')">
                                        <button type="submit" class="btn-oferta-delete" title="Eliminar" aria-label="Eliminar oferta <%= oferta.productoEnOferta.nombre %>">
                                            🗑️
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
            <div class="empty-state-ofertas">
                <p>No hay ofertas individuales registradas</p>
                <a href="/administrador/ofertas/agregar-oferta-individual" class="btn-primary-modern">
                    <span class="btn-icon">+</span>
                    Crear Primera Oferta
                </a>
            </div>
            <% } %>
        </div>

        <!-- Ofertas Conjunto -->
        <div class="ofertas-section">
            <h2 class="ofertas-section-title">🎯 Ofertas Conjunto</h2>
            
            <% if (ofertasConjunto && ofertasConjunto.length > 0) { %>
            <div class="ofertas-table-wrapper">
                <table class="ofertas-table" aria-label="Listado de ofertas conjunto">
                    <thead>
                        <tr>
                            <th>Nombre de Oferta</th>
                            <th style="text-align: center;">Precio Oferta</th>
                            <th style="text-align: center;">Productos Incluidos</th>
                            <th style="text-align: center;">Vigencia</th>
                            <th style="text-align: center;">Estado</th>
                            <th style="text-align: center;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% ofertasConjunto.forEach(oferta => { %>
                        <tr class="oferta-row">
                            <td data-label="Nombre:">
                                <div class="oferta-product-cell">
                                    <span class="product-icon">🎯</span>
                                    <div>
                                        <a href="/administrador/ofertas/oferta-conjunto/<%= oferta._id %>" class="product-link">
                                            <%= oferta.nombreOferta %>
                                        </a>
                                        <div><small>Cód. oferta: <%= oferta.codigoOferta || '-' %></small></div>
                                    </div>
                                </div>
                            </td>
                            <td data-label="Precio:" style="text-align: center;">
                                <span class="price-badge">$<%= oferta.precioOferta.toFixed(2) %></span>
                            </td>
                            <td data-label="Productos:" style="text-align: center;">
                                <span class="quantity-badge">
                                    <%= oferta.productosEnOfertaConCodigo ? oferta.productosEnOfertaConCodigo.length : 0 %> productos
                                </span>
                            </td>
                            <td data-label="Vigencia:" style="text-align: center;">
                                <span class="date-badge">
                                    <%= oferta.fechaDeVigencia ? new Date(oferta.fechaDeVigencia).toLocaleDateString('es-AR') : '-' %>
                                </span>
                            </td>
                            <td data-label="Estado:" style="text-align: center;">
                                <span class="status-pill <%= (oferta.estado || 'ACTIVA') === 'PAUSADA' ? 'is-paused' : 'is-active' %>">
                                    <%= oferta.estado || 'ACTIVA' %>
                                </span>
                            </td>
                            <td data-label="Acciones:" style="text-align: center;">
                                <div class="oferta-actions">
                                    <a href="/administrador/ofertas/oferta-conjunto/<%= oferta._id %>" class="btn-oferta-view" title="Ver detalles" aria-label="Ver detalle de la oferta <%= oferta.nombreOferta %>">
                                        👁️
                                    </a>
                                    <form action="/administrador/ofertas/oferta-conjunto/<%= oferta._id %>/estado" 
                                          method="POST" 
                                          class="inline-action-form">
                                        <input type="hidden" name="estado" value="<%= (oferta.estado || 'ACTIVA') === 'PAUSADA' ? 'ACTIVA' : 'PAUSADA' %>">
                                        <button type="submit" class="btn-oferta-view" title="<%= (oferta.estado || 'ACTIVA') === 'PAUSADA' ? 'Reactivar' : 'Pausar' %>" aria-label="<%= (oferta.estado || 'ACTIVA') === 'PAUSADA' ? 'Reactivar' : 'Pausar' %> oferta <%= oferta.nombreOferta %>">
                                            <%= (oferta.estado || 'ACTIVA') === 'PAUSADA' ? '▶️' : '⏸️' %>
                                        </button>
                                    </form>
                                    <form action="/administrador/ofertas/oferta-conjunto/<%= oferta._id %>?_method=DELETE" 
                                          method="POST" 
                                          class="inline-action-form"
                                          onsubmit="return confirm('¿Eliminar esta oferta?')">
                                        <button type="submit" class="btn-oferta-delete" title="Eliminar" aria-label="Eliminar oferta <%= oferta.nombreOferta %>">
                                            🗑️
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
            <div class="empty-state-ofertas">
                <p>No hay ofertas conjunto registradas</p>
                <a href="/administrador/ofertas/agregar-oferta-conjunto" class="btn-primary-modern">
                    <span class="btn-icon">+</span>
                    Crear Primera Oferta
                </a>
            </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('../partials/footer.ejs'); %>
