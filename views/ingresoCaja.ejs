<%- include('./partials/headerCaja.ejs'); %>
<%- include('./partials/flash.ejs'); %>

<div class="login-container" id="cash-main-content">
    <div class="login-card">
        <div class="login-header">
            <div class="login-icon">💳</div>
            <h1 class="login-title">Acceso a Caja</h1>
            <p class="login-subtitle">Estación: <strong><%= nombreEstacion %></strong></p>
            <p class="security-text">Solo el usuario <strong>CAJA</strong> puede operar aquí</p>
        </div>

        <div class="cash-login-note">
            <strong>Recomendado para escritorio:</strong> operar con monitor horizontal, teclado numérico y lector de código conectado.
        </div>

        <form action="/ingreso-caja/<%= estacionDeCobroId %>/login" method="POST" class="login-form" id="cashLoginForm" autocomplete="on">
            <div class="form-group-modern">
                <label for="username" class="form-label-modern">Usuario</label>
                <input type="text" 
                       id="username" 
                       name="username" 
                       class="form-control-modern" 
                       placeholder="Ingresa tu usuario"
                       autocomplete="username"
                       spellcheck="false"
                       autofocus
                       required>
            </div>

            <div class="form-group-modern">
                <label for="password" class="form-label-modern">Contraseña</label>
                <div class="password-wrapper">
                    <input type="password" 
                           id="password" 
                           name="password" 
                           class="form-control-modern" 
                           placeholder="Ingresa tu contraseña"
                           autocomplete="current-password"
                           required>
                    <button type="button" class="password-toggle" onclick="togglePasswordCaja()" aria-label="Mostrar u ocultar contraseña" aria-controls="password" aria-pressed="false">
                        <span id="eye-icon-caja">👁️</span>
                    </button>
                </div>
            </div>

            <div class="form-check-modern">
                <input type="checkbox" id="remember" name="remember" class="checkbox-modern">
                <label for="remember" class="checkbox-label">Recordar sesión</label>
            </div>

            <button type="submit" class="btn-login-modern">
                <span>Ingresar a Caja</span>
                <span class="btn-arrow">→</span>
            </button>
        </form>

        <div class="login-footer">
            <p class="security-text">🔒 Conexión segura y encriptada</p>
        </div>
    </div>
</div>

<script>
function togglePasswordCaja() {
    const passwordField = document.getElementById('password');
    const eyeIcon = document.getElementById('eye-icon-caja');
    const toggleButton = document.querySelector('.password-toggle');
    
    if (passwordField.type === 'password') {
        passwordField.type = 'text';
        eyeIcon.textContent = '🙈';
        toggleButton?.setAttribute('aria-pressed', 'true');
    } else {
        passwordField.type = 'password';
        eyeIcon.textContent = '👁️';
        toggleButton?.setAttribute('aria-pressed', 'false');
    }
}

(function initRememberCaja() {
    const rememberBox = document.getElementById('remember');
    const usernameField = document.getElementById('username');
    const loginForm = document.getElementById('cashLoginForm');
    const storageKey = 'solidarg-last-user:CAJA';
    const savedUsername = window.localStorage.getItem(storageKey);

    if (savedUsername) {
        usernameField.value = savedUsername;
        rememberBox.checked = true;
    }

    loginForm.addEventListener('submit', () => {
        if (rememberBox.checked) {
            window.localStorage.setItem(storageKey, usernameField.value.trim());
        } else {
            window.localStorage.removeItem(storageKey);
        }
    });
})();
</script>

<%- include('./partials/footer.ejs'); %>
